# ─── Dependencies ──────────────────────────────────────────
node_modules/
.pnpm-store/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions


# ─── Build outputs ─────────────────────────────────────────
dist/
build/
.next/
out/
.turbo/

# ─── Environment files ─────────────────────────────────────
# Never commit real .env files
.env
# DO commit .env.example files (they are templates with no secrets)

# ─── Editor & OS ───────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
.vscode/settings.json
.vscode/launch.json
.idea/

# ─── Testing ───────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
playwright-report/
test-results/

# ─── Prisma ────────────────────────────────────────────────
# Generated client — always regenerated from schema, never commit
apps/api/src/prisma/generated/

# RSA keys — NEVER commit private keys
*.pem
private.key
public.key

# ─── Uploads / media ───────────────────────────────────────
uploads/
public/uploads/

# ─── Misc ──────────────────────────────────────────────────
*.tsbuildinfo
.cache/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
next-env.d.ts
package-lock.json

pnpm-lock.yaml
public/sitemap-0.xml
public/sitemap.xml
public/robots.txt
sideprojectors-saas-docs/