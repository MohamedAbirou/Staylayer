// ─── Form Submission ───────────────────────────────────────

model FormDefinition {
  id                    String               @id @default(cuid())
  siteId                String               @map("site_id")
  key                   String
  name                  String
  description           String               @default("")
  formType              FormType             @map("form_type")
  status                FormDefinitionStatus @default(DRAFT)
  assignment            Json?
  activeSchemaVersionId String?              @map("active_schema_version_id")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  site                Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  activeSchemaVersion FormSchemaVersion?  @relation("ActiveFormSchemaVersion", fields: [activeSchemaVersionId], references: [id], onDelete: SetNull)
  draftFields         FormField[]
  schemaVersions      FormSchemaVersion[] @relation("FormDefinitionSchemaVersions")
  routingRules        FormRoutingRule[]
  emailTemplates      FormEmailTemplate[]
  submissions         FormSubmission[]

  @@unique([siteId, key])
  @@index([siteId, status])
  @@index([siteId, formType])
  @@map("form_definitions")
}

model FormField {
  id                String        @id @default(cuid())
  formDefinitionId  String        @map("form_definition_id")
  key               String
  label             String
  placeholder       String        @default("")
  helpText          String        @default("") @map("help_text")
  type              FormFieldType
  required          Boolean       @default(false)
  sortOrder         Int           @default(0) @map("sort_order")
  validation        Json?
  options           Json?
  defaultValue      String?       @map("default_value")
  isPlatformManaged Boolean       @default(false) @map("is_platform_managed")
  visibilityRules   Json?         @map("visibility_rules")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  formDefinition FormDefinition @relation(fields: [formDefinitionId], references: [id], onDelete: Cascade)

  @@unique([formDefinitionId, key])
  @@index([formDefinitionId, sortOrder])
  @@map("form_fields")
}

model FormSchemaVersion {
  id               String    @id @default(cuid())
  formDefinitionId String    @map("form_definition_id")
  versionNumber    Int       @map("version_number")
  schemaSnapshot   Json      @map("schema_snapshot")
  routingSnapshot  Json?     @map("routing_snapshot")
  emailSnapshot    Json?     @map("email_snapshot")
  createdAt        DateTime  @default(now()) @map("created_at")
  createdBy        String?   @map("created_by")
  publishedAt      DateTime? @map("published_at")

  formDefinition       FormDefinition   @relation("FormDefinitionSchemaVersions", fields: [formDefinitionId], references: [id], onDelete: Cascade)
  activeForDefinitions FormDefinition[] @relation("ActiveFormSchemaVersion")
  submissions          FormSubmission[]

  @@unique([formDefinitionId, versionNumber])
  @@index([formDefinitionId, publishedAt])
  @@map("form_schema_versions")
}

model FormRoutingRule {
  id                          String   @id @default(cuid())
  siteId                      String   @map("site_id")
  formDefinitionId            String?  @map("form_definition_id")
  name                        String   @default("Default route")
  pageSlug                    String?  @map("page_slug")
  locale                      String?
  priority                    Int      @default(0)
  isActive                    Boolean  @default(true) @map("is_active")
  saveToInbox                 Boolean  @default(true) @map("save_to_inbox")
  emailRecipients             String[] @default([]) @map("email_recipients")
  integrationProvider         String   @default("email") @map("integration_provider")
  integrationConfig           Json     @default("{}") @map("integration_config")
  integrationSecret           String   @default("") @map("integration_secret")
  webhookUrl                  String   @default("") @map("webhook_url")
  webhookSecret               String   @default("") @map("webhook_secret")
  sendConfirmationEmail       Boolean  @default(false) @map("send_confirmation_email")
  confirmationReplyToFieldKey String   @default("email") @map("confirmation_reply_to_field_key")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  site           Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  formDefinition FormDefinition?  @relation(fields: [formDefinitionId], references: [id], onDelete: Cascade)
  submissions    FormSubmission[]

  @@index([siteId, isActive, priority])
  @@index([formDefinitionId, isActive, priority])
  @@map("form_routing_rules")
}

model FormEmailTheme {
  id               String   @id @default(cuid())
  siteId           String   @unique @map("site_id")
  brandName        String   @default("") @map("brand_name")
  logoUrl          String   @default("") @map("logo_url")
  primaryColor     String   @default("#2563eb") @map("primary_color")
  accentColor      String   @default("#0f172a") @map("accent_color")
  surfaceColor     String   @default("#ffffff") @map("surface_color")
  textColor        String   @default("#0f172a") @map("text_color")
  typographyFamily String   @default("Arial") @map("typography_family")
  buttonStyle      Json?    @map("button_style")
  cardStyle        Json?    @map("card_style")
  headerContent    Json?    @map("header_content")
  footerContent    Json?    @map("footer_content")
  updatedAt        DateTime @updatedAt @map("updated_at")
  updatedBy        String?  @map("updated_by")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("form_email_themes")
}

model FormEmailTemplate {
  id               String                @id @default(cuid())
  siteId           String                @map("site_id")
  formDefinitionId String?               @map("form_definition_id")
  templateType     FormEmailTemplateType @map("template_type")
  name             String
  enabled          Boolean               @default(true)
  subjectTemplate  String                @map("subject_template")
  previewText      String                @default("") @map("preview_text")
  blocks           Json
  fieldOrder       String[]              @default([]) @map("field_order")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  site           Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  formDefinition FormDefinition? @relation(fields: [formDefinitionId], references: [id], onDelete: Cascade)

  @@index([siteId, templateType])
  @@index([formDefinitionId, templateType])
  @@map("form_email_templates")
}

model FormSubmission {
  id                  String               @id @default(cuid())
  siteId              String               @map("site_id")
  formDefinitionId    String?              @map("form_definition_id")
  formSchemaVersionId String?              @map("form_schema_version_id")
  routingRuleId       String?              @map("routing_rule_id")
  formType            FormType             @map("form_type")
  pageSlug            String?              @map("page_slug")
  locale              String               @default("en")
  payload             Json
  spamScore           Float?               @map("spam_score")
  status              FormSubmissionStatus @default(RECEIVED)
  createdAt           DateTime             @default(now()) @map("created_at")

  site              Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  formDefinition    FormDefinition?    @relation(fields: [formDefinitionId], references: [id], onDelete: SetNull)
  formSchemaVersion FormSchemaVersion? @relation(fields: [formSchemaVersionId], references: [id], onDelete: SetNull)
  routingRule       FormRoutingRule?   @relation(fields: [routingRuleId], references: [id], onDelete: SetNull)
  deliveries        FormDelivery[]

  @@index([siteId])
  @@index([formDefinitionId])
  @@index([formSchemaVersionId])
  @@index([siteId, formType])
  @@index([siteId, status])
  @@index([siteId, createdAt])
  @@map("form_submissions")
}

model FormDelivery {
  id            String              @id @default(cuid())
  submissionId  String              @map("submission_id")
  siteId        String              @map("site_id")
  purpose       FormDeliveryPurpose @default(INTERNAL_NOTIFICATION)
  channel       FormDeliveryChannel
  destination   String
  status        FormDeliveryStatus  @default(PENDING)
  attempts      Int                 @default(0)
  nextAttemptAt DateTime?           @map("next_attempt_at")
  lastAttemptAt DateTime?           @map("last_attempt_at")
  deliveredAt   DateTime?           @map("delivered_at")
  responseCode  Int?                @map("response_code")
  errorMessage  String?             @map("error_message")
  metadata      Json?
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  submission FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  site       Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([siteId, status])
  @@index([status, nextAttemptAt])
  @@map("form_deliveries")
}

model OperationalAlert {
  id               String                   @id @default(cuid())
  siteId           String                   @map("site_id")
  type             OperationalAlertType
  severity         OperationalAlertSeverity @default(WARNING)
  status           OperationalAlertStatus   @default(OPEN)
  fingerprint      String
  message          String
  metadata         Json?
  firstTriggeredAt DateTime                 @default(now()) @map("first_triggered_at")
  lastTriggeredAt  DateTime                 @default(now()) @map("last_triggered_at")
  resolvedAt       DateTime?                @map("resolved_at")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  seoAuditTasks SeoAuditTask[] @relation("SeoAuditTaskAlert")

  @@unique([siteId, type, fingerprint])
  @@index([status, type])
  @@index([siteId, status])
  @@map("operational_alerts")
}

