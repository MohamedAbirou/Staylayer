// apps/api/src/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────

enum PlatformRole {
  PLATFORM_OWNER
  SUPPORT_ADMIN
  FINANCE_ADMIN
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TenantMembershipRole {
  OWNER
  ADMIN
  EDITOR
  BILLING
}

enum SiteStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum SiteType {
  VACATION_RENTAL
  BOUTIQUE_HOTEL
  BNB
  GLAMPING
  GUEST_HOUSE
}

enum HostVariant {
  APEX
  WWW
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INACTIVE
}

enum DeploymentStatus {
  PENDING
  CREATING_PROJECT
  SYNCING_ENV
  DEPLOYING
  LIVE
  FAILED
  RETRYING
}

enum DeploymentEnvironmentVariableType {
  PLAIN
  ENCRYPTED
}

enum DomainStatus {
  PENDING
  DNS_REQUIRED
  VERIFYING
  PROVIDER_ATTACH_PENDING
  SSL_PROVISIONING
  ACTIVE
  FAILED
}

enum FormType {
  CONTACT
  INQUIRY
  AVAILABILITY_REQUEST
  GROUP_STAY
}

enum FormDefinitionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FormFieldType {
  SINGLE_LINE_TEXT
  MULTI_LINE_TEXT
  EMAIL
  PHONE
  SELECT
  RADIO
  CHECKBOX
  DATE
  NUMBER
  HIDDEN
}

enum FormEmailTemplateType {
  INTERNAL_NOTIFICATION
  GUEST_CONFIRMATION
}

enum FormSubmissionStatus {
  RECEIVED
  REVIEWED
  SPAM
  ARCHIVED
}

enum FormDeliveryChannel {
  EMAIL
  WEBHOOK
}

enum FormDeliveryStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
}

enum FormDeliveryPurpose {
  INTERNAL_NOTIFICATION
  GUEST_CONFIRMATION
  WEBHOOK_FORWARD
}

enum OperationalAlertType {
  DOMAIN_FAILURE
  FORM_DELIVERY_FAILURE
  SUBMISSION_SPIKE
  SEO_AUDIT_REGRESSION
  SEO_AUDIT_CRITICAL
}

enum OperationalAlertSeverity {
  WARNING
  CRITICAL
}

enum OperationalAlertStatus {
  OPEN
  RESOLVED
}

// ─── User ──────────────────────────────────────────────────

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  passwordHash    String        @map("password_hash")
  emailVerifiedAt DateTime?     @map("email_verified_at")
  /// Platform operator role. Null means the account is customer-only.
  platformRole    PlatformRole? @map("platform_role")

  // Brute-force protection
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")

  memberships              TenantMembership[]
  emailVerificationTokens  EmailVerificationToken[]
  passwordResetTokens      PasswordResetToken[]
  sentWorkspaceInvitations WorkspaceInvitation[]    @relation("WorkspaceInvitationSender")
  assignedSeoAuditTasks    SeoAuditTask[]           @relation("SeoAuditTaskAssignee")
  createdSeoAuditTasks     SeoAuditTask[]           @relation("SeoAuditTaskCreator")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([platformRole])
  @@map("users")
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  email      String
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  email      String
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ─── Tenant ────────────────────────────────────────────────

model Tenant {
  id     String       @id @default(cuid())
  slug   String       @unique
  name   String
  status TenantStatus @default(ACTIVE)

  memberships          TenantMembership[]
  sites                Site[]
  subscriptions        Subscription[]
  auditLogs            AuditLog[]
  webhookEvents        BillingWebhookEvent[]
  translationJobs      TranslationJob[]
  glossaries           TranslationGlossary[]
  providerGlossaries   TranslationProviderGlossary[]
  workspaceInvitations WorkspaceInvitation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("tenants")
}

model WorkspaceInvitation {
  id              String               @id @default(cuid())
  tenantId        String               @map("tenant_id")
  email           String
  role            TenantMembershipRole
  tokenHash       String               @unique @map("token_hash")
  invitedByUserId String?              @map("invited_by_user_id")
  expiresAt       DateTime             @map("expires_at")
  acceptedAt      DateTime?            @map("accepted_at")
  revokedAt       DateTime?            @map("revoked_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedByUser User?  @relation("WorkspaceInvitationSender", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, email])
  @@index([email, acceptedAt, revokedAt])
  @@index([expiresAt])
  @@map("workspace_invitations")
}

// ─── Tenant Membership ─────────────────────────────────────

model TenantMembership {
  id        String               @id @default(cuid())
  tenantId  String               @map("tenant_id")
  userId    String               @map("user_id")
  role      TenantMembershipRole
  isDefault Boolean              @default(false) @map("is_default")
  createdAt DateTime             @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, role])
  @@index([userId, isDefault])
  @@map("tenant_memberships")
}

// ─── Site ──────────────────────────────────────────────────

model Site {
  id                      String      @id @default(cuid())
  tenantId                String      @map("tenant_id")
  name                    String
  slug                    String
  publicSubdomain         String?     @unique @map("public_subdomain")
  preferredHostVariant    HostVariant @default(APEX) @map("preferred_host_variant")
  publishedRevision       Int         @default(1) @map("published_revision")
  previewTokenVersion     Int         @default(1) @map("preview_token_version")
  status                  SiteStatus  @default(DRAFT)
  templateKey             String?     @map("template_key")
  primaryLocale           String      @default("en") @map("primary_locale")
  enabledLocales          String[]    @default(["en"]) @map("enabled_locales")
  siteType                SiteType    @default(VACATION_RENTAL) @map("site_type")
  /// Archive snapshot — preserved when the site is moved to ARCHIVED status so
  /// the original public identifiers and detached custom domains can be
  /// surfaced in the trash view and offered for restore.
  archivedAt              DateTime?   @map("archived_at")
  archivedSlug            String?     @map("archived_slug")
  archivedPublicSubdomain String?     @map("archived_public_subdomain")
  archivedDomains         String[]    @default([]) @map("archived_domains")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")

  tenant                         Tenant                              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pages                          Page[]
  settings                       SiteSettings?
  deployments                    Deployment[]
  deploymentEnvironmentVariables SiteDeploymentEnvironmentVariable[]
  domains                        Domain[]
  formDefinitions                FormDefinition[]
  formRoutingRules               FormRoutingRule[]
  formEmailTheme                 FormEmailTheme?
  formEmailTemplates             FormEmailTemplate[]
  formSubmissions                FormSubmission[]
  formDeliveries                 FormDelivery[]
  alerts                         OperationalAlert[]
  auditLogs                      AuditLog[]
  translationJobs                TranslationJob[]
  glossaries                     TranslationGlossary[]
  providerGlossaries             TranslationProviderGlossary[]
  redirects                      Redirect[]
  structuredData                 SiteStructuredData?
  publishedRevisions             SitePublishedRevision[]
  sitemapSubmissionLogs          SitemapSubmissionLog[]
  crawlJobs                      SeoCrawlJob[]
  searchConsoleConnection        SearchConsoleConnection?
  searchConsoleSyncJobs          SearchConsoleSyncJob[]
  searchConsolePagePerformance   SearchConsolePagePerformance[]
  searchConsoleQueryPerformance  SearchConsoleQueryPerformance[]
  searchConsoleSitemaps          SearchConsoleSitemap[]
  searchConsoleUrlInspections    SearchConsoleUrlInspection[]
  psiAudits                      PsiAudit[]
  cruxRecords                    CruxRecord[]
  hreflangScans                  HreflangScan[]
  hreflangIssues                 HreflangIssue[]
  bingWebmasterConnection        BingWebmasterConnection?
  bingSyncJobs                   BingSyncJob[]
  bingPagePerformance            BingPagePerformance[]
  bingQueryPerformance           BingQueryPerformance[]
  bingSitemaps                   BingSitemap[]
  bingCrawlIssues                BingCrawlIssue[]
  bingLinkSummary                BingLinkSummary?
  aiCitationAudits               AiCitationAudit[]
  seoAuditSchedule               SeoAuditSchedule?
  seoAuditRuns                   SeoAuditRun[]
  seoAuditSnapshots              SeoAuditSnapshot[]
  seoAuditTasks                  SeoAuditTask[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@map("sites")
}

// ─── Page ──────────────────────────────────────────────────

model Page {
  id        String  @id @default(cuid())
  /// Every page belongs to exactly one customer site.
  siteId    String  @map("site_id")
  slug      String
  locale    String  @default("en")
  title     String
  puckData  Json    @map("puck_data")
  published Boolean @default(false)

  seoTitle       String? @map("seo_title")
  seoDescription String? @map("seo_description")
  targetKeywords String? @map("target_keywords")
  internalBrief  String? @map("internal_brief")
  seoOgImage     String? @map("seo_og_image")
  seoCanonical   String? @map("seo_canonical")
  seoNoindex     Boolean @default(false) @map("seo_noindex")

  /// Per-page JSON-LD override. Shape:
  /// { mode: "merge" | "replace", disabledTypes: string[], customNodes: object[] }
  jsonLdOverride Json? @map("json_ld_override")

  // Soft delete
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  site               Site                  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  versions           PageVersion[]
  translationMeta    PageTranslationMeta?
  sourceTranslations PageTranslationMeta[] @relation("SourceTranslations")

  @@unique([siteId, slug, locale])
  @@index([siteId])
  @@index([siteId, slug])
  @@index([siteId, locale])
  @@index([siteId, published])
  @@index([siteId, published, locale])
  @@index([siteId, deletedAt])
  @@map("pages")
}

// ─── Page Version ──────────────────────────────────────────

model PageVersion {
  id       String   @id @default(cuid())
  pageId   String   @map("page_id")
  puckData Json     @map("puck_data")
  savedBy  String   @map("saved_by")
  note     String?
  savedAt  DateTime @default(now()) @map("saved_at")

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([pageId, savedAt])
  @@map("page_versions")
}

// ─── Site Settings ─────────────────────────────────────────

model SiteSettings {
  id     String @id @default(cuid())
  siteId String @unique @map("site_id")

  // General
  siteName                   String @default("StayLayer CMS") @map("site_name")
  siteSubtitle               String @default("") @map("site_subtitle")
  supportEmail               String @default("") @map("support_email")
  publicPhone                String @default("") @map("public_phone")
  whatsAppUrl                String @default("") @map("whatsapp_url")
  address                    String @default("") @map("address")
  region                     String @default("") @map("region")
  primaryCtaLabel            String @default("Send inquiry") @map("primary_cta_label")
  defaultInquiryRoutingEmail String @default("") @map("default_inquiry_routing_email")
  inquiryIntegrationProvider String @default("email") @map("inquiry_integration_provider")
  inquiryIntegrationConfig   Json   @default("{}") @map("inquiry_integration_config")
  inquiryIntegrationSecret   String @default("") @map("inquiry_integration_secret")
  inquiryWebhookUrl          String @default("") @map("inquiry_webhook_url")
  inquiryWebhookSecret       String @default("") @map("inquiry_webhook_secret")
  logoUrl                    String @default("") @map("logo_url")
  faviconUrl                 String @default("") @map("favicon_url")

  // SEO Defaults
  seoTitleTemplate    String  @default("%s | StayLayer") @map("seo_title_template")
  seoDefaultDesc      String  @default("") @map("seo_default_desc")
  seoOgImage          String  @default("") @map("seo_og_image")
  seoIndexingEnabled  Boolean @default(true) @map("seo_indexing_enabled")
  seoLocaleDefaults   Json    @default("{}") @map("seo_locale_defaults")
  googleSiteVerify    String  @default("") @map("google_site_verify")
  bingSiteVerify      String  @default("") @map("bing_site_verify")
  yandexSiteVerify    String  @default("") @map("yandex_site_verify")
  pinterestSiteVerify String  @default("") @map("pinterest_site_verify")

  // Analytics
  gaTrackingId   String @default("") @map("ga_tracking_id")
  gtmContainerId String @default("") @map("gtm_container_id")
  clarityId      String @default("") @map("clarity_id")

  // Social
  twitterHandle String @default("") @map("twitter_handle")
  linkedinUrl   String @default("") @map("linkedin_url")
  facebookUrl   String @default("") @map("facebook_url")
  instagramUrl  String @default("") @map("instagram_url")
  youtubeUrl    String @default("") @map("youtube_url")
  tiktokUrl     String @default("") @map("tiktok_url")
  pinterestUrl  String @default("") @map("pinterest_url")

  // Localization
  defaultLocale String   @default("en") @map("default_locale")
  activeLocales String[] @default(["en", "es", "fr", "de", "it", "pt", "nl", "ar"]) @map("active_locales")

  // Robots & sitemap
  robotsCustomRules     String   @default("") @map("robots_custom_rules")
  robotsAiCrawlerPolicy Json     @default("{}") @map("robots_ai_crawler_policy")
  sitemapExcludedPaths  String[] @default([]) @map("sitemap_excluded_paths")
  sitemapIncludeImages  Boolean  @default(true) @map("sitemap_include_images")

  // IndexNow
  indexNowKey     String  @default("") @map("indexnow_key")
  indexNowEnabled Boolean @default(true) @map("indexnow_enabled")

  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("site_settings")
}

// ─── Subscription ──────────────────────────────────────────

model Subscription {
  id                     String             @id @default(cuid())
  tenantId               String             @map("tenant_id")
  provider               String
  providerCustomerId     String?            @map("provider_customer_id")
  providerSubscriptionId String?            @unique @map("provider_subscription_id")
  providerPriceId        String?            @map("provider_price_id")
  planKey                String             @map("plan_key")
  status                 SubscriptionStatus @default(INACTIVE)
  currentPeriodStart     DateTime?          @map("current_period_start")
  currentPeriodEnd       DateTime?          @map("current_period_end")
  cancelAtPeriodEnd      Boolean            @default(false) @map("cancel_at_period_end")
  pendingPlanKey         String?            @map("pending_plan_key")
  pendingPlanEffectiveAt DateTime?          @map("pending_plan_effective_at")
  pendingPlanDirection   String?            @map("pending_plan_direction")
  providerScheduleId     String?            @map("provider_schedule_id")
  limitsSnapshot         Json?              @map("limits_snapshot")
  gracePeriodEndsAt      DateTime?          @map("grace_period_ends_at")
  lastWebhookEventId     String?            @map("last_webhook_event_id")
  lastWebhookAt          DateTime?          @map("last_webhook_at")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  webhookEvents BillingWebhookEvent[]

  @@index([tenantId])
  @@index([status])
  @@map("subscriptions")
}

model BillingWebhookEvent {
  id              String    @id @default(cuid())
  provider        String
  providerEventId String    @unique @map("provider_event_id")
  eventType       String    @map("event_type")
  tenantId        String?   @map("tenant_id")
  subscriptionId  String?   @map("subscription_id")
  payload         Json
  processedAt     DateTime? @map("processed_at")
  errorMessage    String?   @map("error_message")
  createdAt       DateTime  @default(now()) @map("created_at")

  tenant       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([provider, createdAt])
  @@index([tenantId, createdAt])
  @@index([subscriptionId, createdAt])
  @@map("billing_webhook_events")
}

// ─── Deployment ────────────────────────────────────────────

model Deployment {
  id                String           @id @default(cuid())
  siteId            String           @map("site_id")
  status            DeploymentStatus @default(PENDING)
  provider          String?
  providerProjectId String?          @map("provider_project_id")
  providerDeployId  String?          @map("provider_deploy_id")
  url               String?
  metadata          Json?
  errorMessage      String?          @map("error_message")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  site              Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([siteId, status])
  @@index([siteId, createdAt])
  @@map("deployments")
}

// ─── Site Published Revision (content snapshots for shared-runtime rollback) ──

model SitePublishedRevision {
  id               String   @id @default(cuid())
  siteId           String   @map("site_id")
  revision         Int
  pagesSnapshot    Json     @map("pages_snapshot")
  settingsSnapshot Json?    @map("settings_snapshot")
  deploymentId     String?  @map("deployment_id")
  rolledBackFrom   Int?     @map("rolled_back_from")
  createdById      String?  @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, revision])
  @@index([siteId, createdAt])
  @@index([deploymentId])
  @@map("site_published_revisions")
}

model SiteDeploymentEnvironmentVariable {
  id                   String                            @id @default(cuid())
  siteId               String                            @map("site_id")
  key                  String
  type                 DeploymentEnvironmentVariableType @default(PLAIN)
  description          String                            @default("")
  targets              String[]                          @default(["production"])
  encryptedValue       String                            @map("encrypted_value")
  initializationVector String                            @map("initialization_vector")
  authTag              String                            @map("auth_tag")
  createdAt            DateTime                          @default(now()) @map("created_at")
  updatedAt            DateTime                          @updatedAt @map("updated_at")
  updatedBy            String?                           @map("updated_by")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, key])
  @@index([siteId, updatedAt])
  @@map("site_deployment_environment_variables")
}

// ─── Domain ────────────────────────────────────────────────

model Domain {
  id                      String       @id @default(cuid())
  siteId                  String       @map("site_id")
  host                    String       @unique
  status                  DomainStatus @default(PENDING)
  isPrimary               Boolean      @default(false) @map("is_primary")
  verificationRequestedAt DateTime?    @map("verification_requested_at")
  lastCheckedAt           DateTime?    @map("last_checked_at")
  lastError               String?      @map("last_error")
  verificationDetails     Json?        @map("verification_details")
  verifiedAt              DateTime?    @map("verified_at")
  createdAt               DateTime     @default(now()) @map("created_at")
  updatedAt               DateTime     @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([siteId, status])
  @@map("domains")
}

// ─── Form Submission ───────────────────────────────────────

model FormDefinition {
  id                    String               @id @default(cuid())
  siteId                String               @map("site_id")
  key                   String
  name                  String
  description           String               @default("")
  formType              FormType             @map("form_type")
  status                FormDefinitionStatus @default(DRAFT)
  assignment            Json?
  activeSchemaVersionId String?              @map("active_schema_version_id")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  site                Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  activeSchemaVersion FormSchemaVersion?  @relation("ActiveFormSchemaVersion", fields: [activeSchemaVersionId], references: [id], onDelete: SetNull)
  draftFields         FormField[]
  schemaVersions      FormSchemaVersion[] @relation("FormDefinitionSchemaVersions")
  routingRules        FormRoutingRule[]
  emailTemplates      FormEmailTemplate[]
  submissions         FormSubmission[]

  @@unique([siteId, key])
  @@index([siteId, status])
  @@index([siteId, formType])
  @@map("form_definitions")
}

model FormField {
  id                String        @id @default(cuid())
  formDefinitionId  String        @map("form_definition_id")
  key               String
  label             String
  placeholder       String        @default("")
  helpText          String        @default("") @map("help_text")
  type              FormFieldType
  required          Boolean       @default(false)
  sortOrder         Int           @default(0) @map("sort_order")
  validation        Json?
  options           Json?
  defaultValue      String?       @map("default_value")
  isPlatformManaged Boolean       @default(false) @map("is_platform_managed")
  visibilityRules   Json?         @map("visibility_rules")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  formDefinition FormDefinition @relation(fields: [formDefinitionId], references: [id], onDelete: Cascade)

  @@unique([formDefinitionId, key])
  @@index([formDefinitionId, sortOrder])
  @@map("form_fields")
}

model FormSchemaVersion {
  id               String    @id @default(cuid())
  formDefinitionId String    @map("form_definition_id")
  versionNumber    Int       @map("version_number")
  schemaSnapshot   Json      @map("schema_snapshot")
  routingSnapshot  Json?     @map("routing_snapshot")
  emailSnapshot    Json?     @map("email_snapshot")
  createdAt        DateTime  @default(now()) @map("created_at")
  createdBy        String?   @map("created_by")
  publishedAt      DateTime? @map("published_at")

  formDefinition       FormDefinition   @relation("FormDefinitionSchemaVersions", fields: [formDefinitionId], references: [id], onDelete: Cascade)
  activeForDefinitions FormDefinition[] @relation("ActiveFormSchemaVersion")
  submissions          FormSubmission[]

  @@unique([formDefinitionId, versionNumber])
  @@index([formDefinitionId, publishedAt])
  @@map("form_schema_versions")
}

model FormRoutingRule {
  id                          String   @id @default(cuid())
  siteId                      String   @map("site_id")
  formDefinitionId            String?  @map("form_definition_id")
  name                        String   @default("Default route")
  pageSlug                    String?  @map("page_slug")
  locale                      String?
  priority                    Int      @default(0)
  isActive                    Boolean  @default(true) @map("is_active")
  saveToInbox                 Boolean  @default(true) @map("save_to_inbox")
  emailRecipients             String[] @default([]) @map("email_recipients")
  integrationProvider         String   @default("email") @map("integration_provider")
  integrationConfig           Json     @default("{}") @map("integration_config")
  integrationSecret           String   @default("") @map("integration_secret")
  webhookUrl                  String   @default("") @map("webhook_url")
  webhookSecret               String   @default("") @map("webhook_secret")
  sendConfirmationEmail       Boolean  @default(false) @map("send_confirmation_email")
