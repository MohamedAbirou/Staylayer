// ─── PageSpeed Insights + CrUX (Phase B.3) ─────────────────────

enum PsiStrategy {
  MOBILE
  DESKTOP
}

enum PsiAuditStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum CruxFormFactor {
  PHONE
  DESKTOP
  TABLET
  ALL
}

/// One PageSpeed Insights run for a URL on a given strategy.
model PsiAudit {
  id       String         @id @default(cuid())
  siteId   String         @map("site_id")
  url      String
  strategy PsiStrategy
  status   PsiAuditStatus @default(PENDING)

  // Lighthouse category scores in [0,1] (null on failure).
  performanceScore   Float? @map("performance_score")
  accessibilityScore Float? @map("accessibility_score")
  bestPracticesScore Float? @map("best_practices_score")
  seoScore           Float? @map("seo_score")
  pwaScore           Float? @map("pwa_score")

  // Core Web Vitals & key audits (numericValue, ms / unitless for CLS).
  largestContentfulPaintMs Float? @map("lcp_ms")
  firstContentfulPaintMs   Float? @map("fcp_ms")
  cumulativeLayoutShift    Float? @map("cls")
  totalBlockingTimeMs      Float? @map("tbt_ms")
  interactionToNextPaintMs Float? @map("inp_ms")
  speedIndexMs             Float? @map("si_ms")
  timeToInteractiveMs      Float? @map("tti_ms")

  // Provenance.
  lighthouseVersion String?   @map("lighthouse_version")
  userAgent         String?   @map("user_agent")
  fetchTime         DateTime? @map("fetch_time")
  finalUrl          String?   @map("final_url")
  totalByteWeight   Int?      @map("total_byte_weight")
  numRequests       Int?      @map("num_requests")

  // Full responses for drill-down (Lighthouse + loadingExperience snapshots).
  lighthouseResult        Json? @map("lighthouse_result")
  loadingExperience       Json? @map("loading_experience")
  originLoadingExperience Json? @map("origin_loading_experience")

  failureReason String?   @map("failure_reason")
  triggeredBy   String?   @map("triggered_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
  @@index([siteId, url, strategy, createdAt])
  @@index([siteId, status])
  @@map("psi_audits")
}

/// Latest cached Chrome UX Report record per (site, scope, key, formFactor).
/// scope is "URL" or "ORIGIN"; key is either the full URL or the origin.
model CruxRecord {
  id         String         @id @default(cuid())
  siteId     String         @map("site_id")
  scope      String // "URL" | "ORIGIN"
  recordKey  String         @map("record_key") // url or origin
  formFactor CruxFormFactor @map("form_factor")

  // p75 values for headline metrics.
  lcpP75Ms  Int?   @map("lcp_p75_ms")
  fcpP75Ms  Int?   @map("fcp_p75_ms")
  clsP75    Float? @map("cls_p75")
  inpP75Ms  Int?   @map("inp_p75_ms")
  ttfbP75Ms Int?   @map("ttfb_p75_ms")
  fidP75Ms  Int?   @map("fid_p75_ms")

  // Full payload incl. histograms / fractions / collectionPeriod.
  record Json

  collectionPeriodStart DateTime? @map("collection_period_start")
  collectionPeriodEnd   DateTime? @map("collection_period_end")
  fetchedAt             DateTime  @default(now()) @map("fetched_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, scope, recordKey, formFactor])
  @@index([siteId, fetchedAt])
  @@map("crux_records")
}

// ─── Hreflang Matrix (Phase C.1) ──────────────────────────

enum HreflangScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum HreflangIssueType {
  MISSING_LOCALE
  ORPHAN_ALTERNATE
  MISSING_X_DEFAULT
  UNPUBLISHED_SIBLING
  INVALID_LOCALE_CODE
}

enum HreflangIssueSeverity {
  ERROR
  WARNING
  INFO
}

/// One hreflang validation run per site.
model HreflangScan {
  id            String             @id @default(cuid())
  siteId        String             @map("site_id")
  status        HreflangScanStatus @default(PENDING)
  totalSlugs    Int                @default(0) @map("total_slugs")
  totalPages    Int                @default(0) @map("total_pages")
  errorCount    Int                @default(0) @map("error_count")
  warningCount  Int                @default(0) @map("warning_count")
  infoCount     Int                @default(0) @map("info_count")
  defaultLocale String             @map("default_locale")
  activeLocales String[]           @map("active_locales")
  failureReason String?            @map("failure_reason")
  triggeredBy   String?            @map("triggered_by")
  createdAt     DateTime           @default(now()) @map("created_at")
  completedAt   DateTime?          @map("completed_at")

  site   Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  issues HreflangIssue[]

  @@index([siteId, createdAt])
  @@index([siteId, status])
  @@map("hreflang_scans")
}

/// Individual hreflang issue produced by a scan.
model HreflangIssue {
  id          String                @id @default(cuid())
