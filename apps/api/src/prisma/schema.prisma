enum BingWebmasterConnectionStatus {
  ACTIVE
  REVOKED
  ERROR
}

enum BingSyncJobType {
  DAILY
  ON_DEMAND
  SITEMAP_SUBMIT
}

enum BingSyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum BingCrawlIssueSeverity {
  ERROR
  WARNING
  INFO
}

/// One row per (site, Bing Webmaster API key). Stores the encrypted API key
/// and the Bing-verified site URL (`siteUrl`) used as the API parameter.
model BingWebmasterConnection {
  id                   String                        @id @default(cuid())
  siteId               String                        @unique @map("site_id")
  status               BingWebmasterConnectionStatus @default(ACTIVE)
  /// The Bing-verified site, e.g. `https://example.com`. Used as the
  /// `siteUrl` parameter on all Bing Webmaster API calls.
  propertyUrl          String                        @map("property_url")
  /// AES-256-GCM ciphertext of the user-pasted API key.
  encryptedApiKey      String                        @map("encrypted_api_key") @db.Text
  /// First 4 + last 4 chars of the key with `***` in the middle, for UI.
  apiKeyFingerprint    String?                       @map("api_key_fingerprint")
  lastSyncedAt         DateTime?                     @map("last_synced_at")
  lastSuccessfulSyncAt DateTime?                     @map("last_successful_sync_at")
  lastError            String?                       @map("last_error")
  consecutiveFailures  Int                           @default(0) @map("consecutive_failures")
  connectedByUserId    String?                       @map("connected_by_user_id")
  createdAt            DateTime                      @default(now()) @map("created_at")
  updatedAt            DateTime                      @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([lastSyncedAt])
  @@map("bing_webmaster_connection")
}

model BingSyncJob {
  id                String            @id @default(cuid())
  siteId            String            @map("site_id")
  type              BingSyncJobType
  status            BingSyncJobStatus @default(PENDING)
  rangeStart        DateTime?         @map("range_start")
  rangeEnd          DateTime?         @map("range_end")
  pagesSynced       Int               @default(0) @map("pages_synced")
  queriesSynced     Int               @default(0) @map("queries_synced")
  sitemapsSynced    Int               @default(0) @map("sitemaps_synced")
  crawlIssuesSynced Int               @default(0) @map("crawl_issues_synced")
  failureReason     String?           @map("failure_reason")
  startedAt         DateTime?         @map("started_at")
  completedAt       DateTime?         @map("completed_at")
  triggeredBy       String?           @map("triggered_by")
  createdAt         DateTime          @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
  @@index([status])
  @@map("bing_sync_job")
}

/// Daily per-page performance roll-up from Bing GetPageStats.
model BingPagePerformance {
  id          String   @id @default(cuid())
  siteId      String   @map("site_id")
  date        DateTime @db.Date
  page        String
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, date, page])
  @@index([siteId, date])
  @@index([siteId, page])
  @@map("bing_page_performance")
}

/// Daily per-query performance roll-up from Bing GetQueryStats (+ optional page).
model BingQueryPerformance {
  id          String   @id @default(cuid())
  siteId      String   @map("site_id")
  date        DateTime @db.Date
  query       String
  /// Optional page dimension. Empty string `""` means "all pages aggregate"
  /// — Postgres treats NULL as distinct in unique indexes, so we use the
  /// empty-string sentinel to make `@@unique([siteId, date, query, page])`
  /// enforce upsert idempotency.
  page        String   @default("")
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, date, query, page])
  @@index([siteId, date])
  @@index([siteId, query])
  @@map("bing_query_performance")
}

model BingSitemap {
  id             String    @id @default(cuid())
  siteId         String    @map("site_id")
  sitemapUrl     String    @map("sitemap_url")
  /// Free-form Bing-reported status (e.g. `Submitted`, `PendingDownload`).
  status         String?
  lastSubmitted  DateTime? @map("last_submitted")
  lastDownloaded DateTime? @map("last_downloaded")
  errors         Int       @default(0)
  warnings       Int       @default(0)
  urlCount       Int       @default(0) @map("url_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, sitemapUrl])
  @@index([siteId])
  @@map("bing_sitemap")
}

/// One row per crawl issue detected by Bing for a given (site, URL, issue code).
model BingCrawlIssue {
  id              String                 @id @default(cuid())
  siteId          String                 @map("site_id")
  url             String
  /// Bing's numeric or string issue code. We store as string for portability.
  issueCode       String                 @map("issue_code")
  /// Bing's human-readable category (e.g. `Server errors`).
  category        String?
  severity        BingCrawlIssueSeverity @default(WARNING)
  httpCode        Int?                   @map("http_code")
  firstDetectedAt DateTime               @map("first_detected_at")
  lastSeenAt      DateTime               @map("last_seen_at")
  resolvedAt      DateTime?              @map("resolved_at")
  details         Json?
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, url, issueCode])
  @@index([siteId, lastSeenAt])
  @@index([siteId, severity])
  @@map("bing_crawl_issue")
}

/// Per-site backlink snapshot from Bing GetLinkCounts.
model BingLinkSummary {
  id         String   @id @default(cuid())
  siteId     String   @unique @map("site_id")
  totalLinks Int      @default(0) @map("total_links")
  fetchedAt  DateTime @map("fetched_at")
  /// Top referring domains (top 50) — array of `{ domain, count }`.
  topDomains Json?    @map("top_domains")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("bing_link_summary")
}

// ─── Phase E.2: AI Citation Readiness Audit ─────────────────
//
// Per (site, slug, locale) readiness score for citation by LLM answer
// engines (ChatGPT, Perplexity, Claude, Gemini, etc.). Scores are heuristic
// — not predictions — and re-computed on demand or after publish.
model AiCitationAudit {
  id     String @id @default(cuid())
  siteId String @map("site_id")
  slug   String
  locale String

  /// Overall readiness score 0–100.
  score Int
  /// Letter grade derived from score (A/B/C/D/F).
  grade String

  /// Number of distinct entity facts detected (name, address, prices, etc.).
  entityFactCount  Int  @default(0) @map("entity_fact_count")
  /// Number of answer-ready sections (Q&A patterns, definitional sentences).
  answerReadyCount Int  @default(0) @map("answer_ready_count")
  /// Days since the source page was last updated; null if unknown.
  freshnessDays    Int? @map("freshness_days")

  /// Array of `{ code, severity, message, snippet?, locator? }` items.
  findings Json
  /// `{ entityFacts, answerReady, freshness, robots, structuredData }`.
  signals  Json

  analyzedAt DateTime @default(now()) @map("analyzed_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug, locale])
  @@index([siteId, score])
  @@index([siteId, analyzedAt])
  @@map("ai_citation_audits")
}

// ─── Phase E.3: Scheduled SEO audits + history + in-app alerts ──────────

enum SeoAuditScheduleCadence {
  OFF
  DAILY
  WEEKLY
}

enum SeoAuditRunKind {
  SCHEDULED
  MANUAL
}

enum SeoAuditRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

/// Per-site cadence configuration for automated SEO audit runs.
model SeoAuditSchedule {
  id        String                  @id @default(cuid())
  siteId    String                  @unique @map("site_id")
  cadence   SeoAuditScheduleCadence @default(WEEKLY)
  enabled   Boolean                 @default(true)
  /// 0–23 UTC; used as the hour-of-day the next run is scheduled at.
  hourUtc   Int                     @default(3) @map("hour_utc")
  /// 0 = Sunday … 6 = Saturday. Only used when cadence = WEEKLY.
  dayOfWeek Int?                    @map("day_of_week")

  lastRunAt DateTime? @map("last_run_at")
  nextRunAt DateTime? @map("next_run_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([enabled, nextRunAt])
  @@map("seo_audit_schedules")
}

/// One row per audit run (scheduled or manually triggered). Aggregates the
/// per-page snapshots recorded under `SeoAuditSnapshot`.
model SeoAuditRun {
  id            String            @id @default(cuid())
  siteId        String            @map("site_id")
  kind          SeoAuditRunKind   @default(SCHEDULED)
  status        SeoAuditRunStatus @default(RUNNING)
  startedAt     DateTime          @default(now()) @map("started_at")
  finishedAt    DateTime?         @map("finished_at")
  durationMs    Int?              @map("duration_ms")
  pagesAudited  Int               @default(0) @map("pages_audited")
  alertsCreated Int               @default(0) @map("alerts_created")
  /// Average AI-citation score across pages audited in this run.
  averageScore  Int?              @map("average_score")
  /// First error message if `status = FAILED`.
  error         String?
  triggeredBy   String?           @map("triggered_by")

  site      Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  snapshots SeoAuditSnapshot[]

  @@index([siteId, startedAt])
  @@index([status])
  @@map("seo_audit_runs")
}

/// Per-page snapshot recorded by an audit run. Used to render score-history
/// sparklines and to diff against previous runs to surface regressions.
model SeoAuditSnapshot {
  id               String   @id @default(cuid())
  runId            String   @map("run_id")
  siteId           String   @map("site_id")
  slug             String
  locale           String
  score            Int
  grade            String
  entityFactCount  Int      @default(0) @map("entity_fact_count")
  answerReadyCount Int      @default(0) @map("answer_ready_count")
  findingsCount    Int      @default(0) @map("findings_count")
  allowsCitation   Boolean  @default(true) @map("allows_citation")
  recordedAt       DateTime @default(now()) @map("recorded_at")

  run  SeoAuditRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  site Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, slug, locale, recordedAt])
  @@index([runId])
  @@map("seo_audit_snapshots")
}

// ─── Phase E.4: Bulk SEO audit workflow (tasks + assignment) ────────────

enum SeoAuditTaskStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum SeoAuditTaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SeoAuditTaskSource {
  ALERT
  MANUAL
}

/// Triage item layered on top of audit findings. Each task corresponds to a
/// single page (slug + locale) and may optionally link to the originating
/// `OperationalAlert`. `assigneeUserId` is nullable — unassigned is valid.
model SeoAuditTask {
  id              String               @id @default(cuid())
  siteId          String               @map("site_id")
  sourceAlertId   String?              @unique @map("source_alert_id")
  source          SeoAuditTaskSource   @default(MANUAL)
  slug            String
  locale          String
  title           String
  description     String?
  status          SeoAuditTaskStatus   @default(OPEN)
  priority        SeoAuditTaskPriority @default(MEDIUM)
  /// Tenant-scoped assignee. Null means unassigned. Validated against
  /// TenantMembership at the service layer.
  assigneeUserId  String?              @map("assignee_user_id")
  createdByUserId String?              @map("created_by_user_id")
  resolvedAt      DateTime?            @map("resolved_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  site        Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sourceAlert OperationalAlert? @relation("SeoAuditTaskAlert", fields: [sourceAlertId], references: [id], onDelete: SetNull)
  assignee    User?             @relation("SeoAuditTaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  createdBy   User?             @relation("SeoAuditTaskCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([siteId, status])
  @@index([siteId, assigneeUserId, status])
  @@index([siteId, priority, status])
  @@index([siteId, slug, locale])
  @@map("seo_audit_tasks")
}

// ─── Phase 3: Operator refresh sessions + audit log ─────────────────────

/// Persistent server-side record for an operator refresh token. Each issued
/// refresh JWT carries a unique JTI claim that points to a row here so the
/// session can be revoked on logout, on role revocation, or out-of-band by
/// a Platform Owner. Rows are deleted by a periodic cleanup job once both
/// `expiresAt` and `revokedAt` are in the past — see Phase 11.
model OperatorRefreshSession {
  id                  String    @id @default(cuid())
  /// JWT `jti` claim. Unique across all operator refresh tokens, ever.
  jti                 String    @unique
  userId              String    @map("user_id")
  /// SHA-256 hash (first 32 hex chars) of the User-Agent header at issuance.
  /// Used to surface "Unknown device" warnings without storing raw UA strings.
  userAgentHash       String?   @map("user_agent_hash")
  /// SHA-256 hash (first 32 hex chars) of the client IP at issuance. Never
  /// the raw IP — we only need to detect re-use from a different network.
  ipHash              String?   @map("ip_hash")
  createdAt           DateTime  @default(now()) @map("created_at")
  lastUsedAt          DateTime  @default(now()) @map("last_used_at")
  expiresAt           DateTime  @map("expires_at")
  revokedAt           DateTime? @map("revoked_at")
  /// Optional reason recorded when the session is revoked
  /// (`logout`, `rotated`, `role_revoked`, `admin_revoked`).
  revokedReason       String?   @map("revoked_reason")
  /// When the token is rotated on refresh, the new session points back at
  /// the one it replaced so a stolen-token detector can walk the chain.
  replacedBySessionId String?   @map("replaced_by_session_id")

  user User @relation("OperatorRefreshSessionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("operator_refresh_sessions")
}

/// Phase 12 — one-time MFA recovery codes for operator accounts. Each row
/// stores a SHA-256 hash of the recovery code (the plaintext is shown to
/// the operator at enrollment time and never persisted). Consuming a code
/// flips `consumedAt`; the row is kept so the operator can audit usage.
model OperatorMfaRecoveryCode {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  /// SHA-256 hex of the plaintext code. Indexed for constant-time lookup.
  codeHash   String    @unique @map("code_hash")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation("OperatorMfaRecoveryCodeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@map("operator_mfa_recovery_codes")
}

/// Append-only audit trail of operator console actions. Written by the
/// `OperatorAuditInterceptor` for any handler decorated with
/// `@OperatorAudit(...)`. Rows MUST NOT be updated or deleted by the app —
/// retention/archival is handled out-of-band.
model OperatorAuditLog {
  id             String   @id @default(cuid())
  /// Server-generated request id (matches `X-Request-Id` response header).
  requestId      String   @map("request_id")
  /// Operator user that initiated the action.
  actorUserId    String   @map("actor_user_id")
  /// Snapshot of the platform role at the time of the action. Stored as a
  /// string (not the enum) so future role renames do not invalidate history.
  platformRole   String   @map("platform_role")
  /// Stable machine action identifier, e.g. `tenant.suspend`,
  /// `billing.subscription.change_plan`.
  action         String
  /// Permission keys declared by `@RequireOperatorPermissions` on the
  /// handler. Captured for traceability.
  permissionKeys String[] @map("permission_keys")
  targetType     String?  @map("target_type")
  targetId       String?  @map("target_id")
  tenantId       String?  @map("tenant_id")
  siteId         String?  @map("site_id")
  method         String
  path           String
  statusCode     Int      @map("status_code")
  durationMs     Int      @map("duration_ms")
  /// True for actions marked `sensitive: true` (billing mutations, refunds,
  /// suspensions). Requires a non-empty `reason`.
  sensitive      Boolean  @default(false)
  /// Reason text supplied by the operator on sensitive mutations. Truncated
  /// to 2000 chars by the interceptor.
  reason         String?
  ipHash         String?  @map("ip_hash")
  userAgentHash  String?  @map("user_agent_hash")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  actor User @relation("OperatorAuditLogActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([tenantId, createdAt])
  @@index([targetType, targetId])
  @@index([requestId])
  @@map("operator_audit_logs")
}

// --- Phase 5: Support System -------------------------------------------
//
// Native support case schema described in
// `operator-console-docs/03-support-system.md`. Cases are the canonical
// record for every customer-affecting interaction, regardless of channel
// (manual, inbound email, system alert, billing handoff, etc.). Rows are
// scoped to a tenant and optionally a site; cross-tenant ownership lives in
// `assignedOperatorId` (operator user) and `requesterUserId` (customer
// user). Mutations are audited via `OperatorAuditLog`; per-case timeline
// events live on `SupportCaseEvent` so the UI can render an inline,
// non-PII history without joining the operator audit table.

enum SupportCaseStatus {
  OPEN
  PENDING_CUSTOMER
  PENDING_INTERNAL
  RESOLVED
  CLOSED
}

enum SupportCasePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportCaseCategory {
  BILLING
  DEPLOYMENT
  DOMAIN
  FORMS
  SEO
  TRANSLATION
  ACCESS
  CONTENT
  ACCOUNT
  OTHER
}

enum SupportCaseChannel {
  MANUAL
  EMAIL
  CUSTOMER_WORKSPACE
  SYSTEM_ALERT
  BILLING
  WEBHOOK
}

enum SupportCaseEventType {
  CREATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  CATEGORY_CHANGED
  ASSIGNMENT_CHANGED
  TAGS_UPDATED
  MESSAGE_ADDED
  NOTE_ADDED
  RESOURCE_LINKED
  RESOURCE_UNLINKED
  HANDOFF_OPENED
  HANDOFF_ACKNOWLEDGED
  HANDOFF_CLOSED
  RESOLVED
  REOPENED
  CLOSED
  SLA_BREACHED
}

enum SupportLinkedResourceType {
  TENANT
  SITE
  DEPLOYMENT
  DOMAIN
  FORM_DEFINITION
  FORM_SUBMISSION
  SUBSCRIPTION
  OPERATIONAL_ALERT
  USER
}

enum SupportHandoffTarget {
  BILLING
  PLATFORM_OWNER
  SUPPORT
}

enum SupportHandoffStatus {
  OPEN
  ACKNOWLEDGED
  CLOSED
}

model SupportCase {
  id                       String              @id @default(cuid())
  /// Human-readable monotonically increasing identifier surfaced to
  /// operators as `#1042`. Generated by the database sequence so concurrent
  /// inserts cannot collide.
  number                   Int                 @unique @default(autoincrement())
  tenantId                 String              @map("tenant_id")
  siteId                   String?             @map("site_id")
  /// Customer user that originated the case (may be null for cases opened
  /// by an operator on the customer's behalf or by a system signal).
  requesterUserId          String?             @map("requester_user_id")
  /// Verbatim email of the requester for cases not tied to a known user.
  requesterEmail           String?             @map("requester_email")
  subject                  String
  channel                  SupportCaseChannel  @default(MANUAL)
  status                   SupportCaseStatus   @default(OPEN)
  priority                 SupportCasePriority @default(NORMAL)
  category                 SupportCaseCategory @default(OTHER)
  /// Free-form tag list. Kept as a denormalised array so queue filters can
  /// rely on a GIN index without a join.
  tags                     String[]            @default([])
  assignedOperatorId       String?             @map("assigned_operator_id")
  createdByOperatorId      String?             @map("created_by_operator_id")
  /// SLA targets resolved at creation time from category + priority. Stored
  /// rather than computed so an SLA breach is auditable even if the policy
  /// matrix later changes.
  firstResponseDueAt       DateTime?           @map("first_response_due_at")
  resolutionDueAt          DateTime?           @map("resolution_due_at")
  firstResponseAt          DateTime?           @map("first_response_at")
  resolvedAt               DateTime?           @map("resolved_at")
  closedAt                 DateTime?           @map("closed_at")
  slaBreachedFirstResponse Boolean             @default(false) @map("sla_breached_first_response")
  slaBreachedResolution    Boolean             @default(false) @map("sla_breached_resolution")
  /// Maintained by the lifecycle service so queue ordering is stable even
  /// when audit/event rows are written asynchronously.
  lastActivityAt           DateTime            @default(now()) @map("last_activity_at")
  /// Arbitrary structured payload supplied by inbound channels (e.g. the
  /// original `OperationalAlert.id` or the inbound email message-id). Must
  /// not contain PII beyond what the channel itself carries.
  metadata                 Json?
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  tenant            Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site              Site?  @relation(fields: [siteId], references: [id], onDelete: SetNull)
  requesterUser     User?  @relation("SupportCaseRequester", fields: [requesterUserId], references: [id], onDelete: SetNull)
  assignedOperator  User?  @relation("SupportCaseAssignee", fields: [assignedOperatorId], references: [id], onDelete: SetNull)
  createdByOperator User?  @relation("SupportCaseCreator", fields: [createdByOperatorId], references: [id], onDelete: SetNull)

  messages        SupportCaseMessage[]
  notes           SupportCaseNote[]
  events          SupportCaseEvent[]
  assignments     SupportCaseAssignment[]
  linkedResources SupportCaseLinkedResource[]
  handoffs        SupportCaseHandoff[]

  @@index([status, priority, lastActivityAt])
  @@index([assignedOperatorId, status])
  @@index([tenantId, status])
  @@index([category, status])
  @@index([createdAt])
  @@index([tags])
  @@map("support_cases")
}

model SupportCaseMessage {
  id               String   @id @default(cuid())
  caseId           String   @map("case_id")
  /// Operator user that authored the message. `null` indicates an inbound
  /// customer message captured by a future inbound channel.
  authorUserId     String?  @map("author_user_id")
  /// `true` for operator replies (visible-to-customer), `false` for
  /// captured inbound customer messages. Notes are stored separately on
  /// `SupportCaseNote` so they cannot be exposed in a customer thread by
  /// accident.
  authorIsOperator Boolean  @default(true) @map("author_is_operator")
  body             String
  createdAt        DateTime @default(now()) @map("created_at")

  case   SupportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author User?       @relation("SupportCaseMessageAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
  @@map("support_case_messages")
}

model SupportCaseNote {
  id           String   @id @default(cuid())
  caseId       String   @map("case_id")
  authorUserId String   @map("author_user_id")
  body         String
  createdAt    DateTime @default(now()) @map("created_at")

  case   SupportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author User        @relation("SupportCaseNoteAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([caseId, createdAt])
  @@map("support_case_notes")
}

model SupportCaseEvent {
  id          String               @id @default(cuid())
  caseId      String               @map("case_id")
  type        SupportCaseEventType
  actorUserId String?              @map("actor_user_id")
  /// Stringified previous value for status/priority/category changes.
  fromValue   String?              @map("from_value")
  toValue     String?              @map("to_value")
  /// Short human-readable message for the UI timeline (e.g. assignment
  /// reasons, handoff target). Never contains customer PII.
  message     String?
  metadata    Json?
  createdAt   DateTime             @default(now()) @map("created_at")

  case  SupportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  actor User?       @relation("SupportCaseEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
  @@index([type, createdAt])
  @@map("support_case_events")
}

model SupportCaseAssignment {
  id              String   @id @default(cuid())
  caseId          String   @map("case_id")
  fromUserId      String?  @map("from_user_id")
  toUserId        String?  @map("to_user_id")
  changedByUserId String   @map("changed_by_user_id")
  reason          String?
  createdAt       DateTime @default(now()) @map("created_at")

  case      SupportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fromUser  User?       @relation("SupportCaseAssignmentFrom", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser    User?       @relation("SupportCaseAssignmentTo", fields: [toUserId], references: [id], onDelete: SetNull)
  changedBy User        @relation("SupportCaseAssignmentChangedBy", fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([caseId, createdAt])
  @@map("support_case_assignments")
}

model SupportCaseLinkedResource {
  id              String                    @id @default(cuid())
  caseId          String                    @map("case_id")
  resourceType    SupportLinkedResourceType @map("resource_type")
  /// Opaque identifier for the linked resource. Validated against the
  /// matching domain table by the lifecycle service at link time.
  resourceId      String                    @map("resource_id")
  label           String?
  createdByUserId String                    @map("created_by_user_id")
  createdAt       DateTime                  @default(now()) @map("created_at")

  case      SupportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy User        @relation("SupportCaseLinkedResourceBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@unique([caseId, resourceType, resourceId])
  @@index([resourceType, resourceId])
  @@map("support_case_linked_resources")
}

model SupportCaseHandoff {
  id             String               @id @default(cuid())
  caseId         String               @map("case_id")
  target         SupportHandoffTarget
  status         SupportHandoffStatus @default(OPEN)
  /// Mandatory free-text reason � captured because handoffs are sensitive
  /// operator actions per the audit policy.
  reason         String
  openedByUserId String               @map("opened_by_user_id")
  closedByUserId String?              @map("closed_by_user_id")
  acknowledgedAt DateTime?            @map("acknowledged_at")
  closedAt       DateTime?            @map("closed_at")
  createdAt      DateTime             @default(now()) @map("created_at")

  case     SupportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  openedBy User        @relation("SupportCaseHandoffOpenedBy", fields: [openedByUserId], references: [id], onDelete: Restrict)
  closedBy User?       @relation("SupportCaseHandoffClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
  @@index([target, status])
  @@map("support_case_handoffs")
}

// --- Phase 7: Billing Control --------------------------------------------
//
// Billing operations cockpit described in
// `operator-console-docs/04-billing-control-system.md`. The Stripe webhook
// snapshot (`BillingWebhookEvent`) and `Subscription` remain the only
// columns the BillingService mutates in the customer-facing flow. The
// models below are owned exclusively by the operator console:
//
//  - `BillingInvoiceSnapshot` / `BillingPaymentEvent` capture provider
//    activity so operators can audit invoice/payment history without
//    re-fetching Stripe on every page load.
//  - `BillingOperatorNote` is an internal-only timeline visible to
//    FINANCE_ADMIN / PLATFORM_OWNER. Customers never see it.
//  - `BillingActionRequest` captures every sensitive billing mutation with
//    before/after snapshots, reason, optional approver, and execution
//    result. Combined with `OperatorAuditLog`, it answers "who changed
//    what, why, and what was the state before/after".
//  - `BillingEntitlementOverride` lets PLATFORM_OWNER lift a single plan
//    limit for a tenant without mutating the plan catalog. Overrides are
//    bounded (optional `expiresAt`) and auditable.

enum BillingActionType {
  CHANGE_PLAN
  CANCEL_PENDING_PLAN_CHANGE
  CANCEL_AT_PERIOD_END
  REACTIVATE_SUBSCRIPTION
  EXTEND_GRACE_PERIOD
  REFUND_INVOICE
  ISSUE_CREDIT
  ENTITLEMENT_OVERRIDE_CREATE
  ENTITLEMENT_OVERRIDE_REVOKE
  STRIPE_WEBHOOK_REPLAY
  STRIPE_SYNC
}

enum BillingActionStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXECUTED
  FAILED
  CANCELED
}

model BillingInvoiceSnapshot {
  id                 String    @id @default(cuid())
  tenantId           String    @map("tenant_id")
  subscriptionId     String?   @map("subscription_id")
  provider           String
  providerInvoiceId  String    @unique @map("provider_invoice_id")
  providerCustomerId String?   @map("provider_customer_id")
  status             String
  amountDue          Int       @map("amount_due")
  amountPaid         Int       @map("amount_paid")
  amountRemaining    Int       @default(0) @map("amount_remaining")
  currency           String
  hostedInvoiceUrl   String?   @map("hosted_invoice_url")
  invoicePdfUrl      String?   @map("invoice_pdf_url")
  periodStart        DateTime? @map("period_start")
  periodEnd          DateTime? @map("period_end")
  providerCreatedAt  DateTime? @map("provider_created_at")
  syncedAt           DateTime  @default(now()) @map("synced_at")
  raw                Json?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription  Subscription?         @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  paymentEvents BillingPaymentEvent[]

  @@index([tenantId, providerCreatedAt])
  @@index([status, providerCreatedAt])
  @@index([subscriptionId, providerCreatedAt])
  @@map("billing_invoice_snapshots")
}

model BillingPaymentEvent {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  subscriptionId    String?  @map("subscription_id")
  invoiceSnapshotId String?  @map("invoice_snapshot_id")
  provider          String
  providerEventId   String   @unique @map("provider_event_id")
  eventType         String   @map("event_type")
  amount            Int?
  currency          String?
  status            String
  occurredAt        DateTime @map("occurred_at")
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at")

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription?           @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice      BillingInvoiceSnapshot? @relation(fields: [invoiceSnapshotId], references: [id], onDelete: SetNull)

  @@index([tenantId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("billing_payment_events")
}

model BillingOperatorNote {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  authorUserId String   @map("author_user_id")
  body         String
  pinned       Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author User   @relation("BillingOperatorNoteAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, pinned, createdAt])
  @@map("billing_operator_notes")
}

model BillingActionRequest {
  id                String              @id @default(cuid())
  tenantId          String              @map("tenant_id")
  /// Operator user that initiated the action.
  actorUserId       String              @map("actor_user_id")
  type              BillingActionType
  status            BillingActionStatus @default(EXECUTED)
  /// True if the action requires a separate approver before execution.
  /// High-risk actions (refunds, entitlement overrides, credits) are
  /// recorded with `PENDING_APPROVAL` until a Platform Owner approves.
  requiresApproval  Boolean             @default(false) @map("requires_approval")
  reason            String
  /// Stripe / external object ids touched by this action (subscription id,
  /// invoice id, refund id, etc.). Indexed for cross-referencing.
  providerObjectIds Json?               @map("provider_object_ids")
  /// Idempotency key for downstream Stripe calls so retries don't double
  /// charge / double refund.
  idempotencyKey    String?             @unique @map("idempotency_key")
  beforeSnapshot    Json?               @map("before_snapshot")
  afterSnapshot     Json?               @map("after_snapshot")
  approverUserId    String?             @map("approver_user_id")
  approverReason    String?             @map("approver_reason")
  approvedAt        DateTime?           @map("approved_at")
  executedAt        DateTime?           @map("executed_at")
  failureCode       String?             @map("failure_code")
  failureMessage    String?             @map("failure_message")
  /// Free-form payload supplied at request time (e.g. target plan key,
  /// refund amount). Validated server-side.
  payload           Json?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor    User   @relation("BillingActionRequestActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  approver User?  @relation("BillingActionRequestApprover", fields: [approverUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([status, createdAt])
  @@index([type, createdAt])
  @@map("billing_action_requests")
}

model BillingEntitlementOverride {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  /// Limit key from `BillingPlanLimits` (e.g. `sites`, `seats`,
  /// `pages`, `translationCharactersPerMonth`). Stored as a free-form
  /// string so the catalog can evolve without a schema migration.
  limitKey        String    @map("limit_key")
  /// Integer override value applied on top of the plan baseline.
  /// `null` means "no numeric override" (used when overriding boolean
  /// flags like `rollbackEnabled` instead).
  intValue        Int?      @map("int_value")
  /// JSON payload for non-integer overrides (booleans, allowed-language
  /// lists, etc.). Mutually exclusive with `intValue`.
  jsonValue       Json?     @map("json_value")
  reason          String
  expiresAt       DateTime? @map("expires_at")
  createdByUserId String    @map("created_by_user_id")
  revokedAt       DateTime? @map("revoked_at")
  revokedByUserId String?   @map("revoked_by_user_id")
  revokeReason    String?   @map("revoke_reason")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("BillingEntitlementOverrideCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  revokedBy User?  @relation("BillingEntitlementOverrideRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, revokedAt, expiresAt])
  @@index([limitKey])
  @@map("billing_entitlement_overrides")
}
