enum SearchConsoleConnectionStatus {
  ACTIVE
  REVOKED
  ERROR
  EXPIRED
}

enum SearchConsoleSyncJobType {
  DAILY
  ON_DEMAND
  SITEMAP_SUBMIT
  URL_INSPECTION
}

enum SearchConsoleSyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

/// One row per (site, Google account). Holds the encrypted refresh token and
/// the Search Console property URL (siteUrl) to use for API calls.
model SearchConsoleConnection {
  id                    String                        @id @default(cuid())
  siteId                String                        @unique @map("site_id")
  status                SearchConsoleConnectionStatus @default(ACTIVE)
  googleAccountEmail    String?                       @map("google_account_email")
  googleAccountSubject  String?                       @map("google_account_subject")
  /// Search Console "siteUrl" property — e.g. "https://example.com/" or "sc-domain:example.com".
  propertyUrl           String                        @map("property_url")
  scope                 String
  encryptedRefreshToken String                        @map("encrypted_refresh_token") @db.Text
  /// Cached access token + expiry, refreshed lazily.
  accessTokenCache      String?                       @map("access_token_cache") @db.Text
  accessTokenExpiresAt  DateTime?                     @map("access_token_expires_at")
  lastSyncedAt          DateTime?                     @map("last_synced_at")
  lastSuccessfulSyncAt  DateTime?                     @map("last_successful_sync_at")
  lastError             String?                       @map("last_error")
  consecutiveFailures   Int                           @default(0) @map("consecutive_failures")
  connectedByUserId     String?                       @map("connected_by_user_id")
  createdAt             DateTime                      @default(now()) @map("created_at")
  updatedAt             DateTime                      @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([lastSyncedAt])
  @@map("search_console_connection")
}

/// Sync job history (daily cron + on-demand). One row per attempted run.
model SearchConsoleSyncJob {
  id             String                     @id @default(cuid())
