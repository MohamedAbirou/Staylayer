// ─── SEO Crawler (technical audit) ────────────────────────

enum SeoCrawlJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum SeoCrawlIssueSeverity {
  ERROR
  WARNING
  INFO
}

enum SeoCrawlIssueCategory {
  META
  CONTENT
  LINKS
  IMAGES
  PERFORMANCE
  INDEXABILITY
  STRUCTURED_DATA
  ACCESSIBILITY
}

enum ImageAltQuality {
  MISSING
  EMPTY
  FILENAME_LIKE
  TOO_SHORT
  TOO_LONG
  GOOD
}

model SeoCrawlJob {
  id                  String            @id @default(cuid())
  siteId              String            @map("site_id")
  status              SeoCrawlJobStatus @default(PENDING)
  startUrl            String            @map("start_url")
  canonicalHost       String            @map("canonical_host")
  urlLimit            Int               @map("url_limit")
  maxDepth            Int               @map("max_depth")
  totalUrls           Int               @default(0) @map("total_urls")
  completedUrls       Int               @default(0) @map("completed_urls")
  errorCount          Int               @default(0) @map("error_count")
  warningCount        Int               @default(0) @map("warning_count")
  infoCount           Int               @default(0) @map("info_count")
  brokenLinkCount     Int               @default(0) @map("broken_link_count")
  imageTotal          Int               @default(0) @map("image_total")
  imageMissingAlt     Int               @default(0) @map("image_missing_alt")
  imageFilenameAlt    Int               @default(0) @map("image_filename_alt")
  imageOversizedOg    Int               @default(0) @map("image_oversized_og")
  imageUndersizedOg   Int               @default(0) @map("image_undersized_og")
  imageMissingDims    Int               @default(0) @map("image_missing_dims")
  imageNotLazy        Int               @default(0) @map("image_not_lazy")
  imageMissingSitemap Int               @default(0) @map("image_missing_sitemap")
  durationMs          Int?              @map("duration_ms")
  failureReason       String?           @map("failure_reason")
  startedAt           DateTime?         @map("started_at")
  completedAt         DateTime?         @map("completed_at")
  createdBy           String?           @map("created_by")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  site          Site                   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  results       SeoCrawlUrlResult[]
  issues        SeoCrawlIssue[]
  imageFindings SeoCrawlImageFinding[]

  @@index([siteId, createdAt(sort: Desc)])
  @@index([status])
  @@map("seo_crawl_job")
}

model SeoCrawlUrlResult {
  id                   String   @id @default(cuid())
  crawlJobId           String   @map("crawl_job_id")
  url                  String
  pathname             String
  depth                Int      @default(0)
  statusCode           Int      @map("status_code")
  contentType          String?  @map("content_type")
  contentLength        Int?     @map("content_length")
  responseTimeMs       Int      @default(0) @map("response_time_ms")
  title                String?
  metaDescription      String?  @map("meta_description")
  canonical            String?
  h1Count              Int      @default(0) @map("h1_count")
  h1First              String?  @map("h1_first")
  h2Count              Int      @default(0) @map("h2_count")
  h3Count              Int      @default(0) @map("h3_count")
  wordCount            Int      @default(0) @map("word_count")
  imageCount           Int      @default(0) @map("image_count")
  imagesMissingAlt     Int      @default(0) @map("images_missing_alt")
  internalLinks        Int      @default(0) @map("internal_links")
  externalLinks        Int      @default(0) @map("external_links")
  brokenLinks          Int      @default(0) @map("broken_links")
  redirectChain        Json     @default("[]") @map("redirect_chain")
  finalUrl             String?  @map("final_url")
  robotsHeader         String?  @map("robots_header")
  indexable            Boolean  @default(true)
  noindexReason        String?  @map("noindex_reason")
  errorCount           Int      @default(0) @map("error_count")
  warningCount         Int      @default(0) @map("warning_count")
  fetchError           String?  @map("fetch_error")
  ogImage              String?  @map("og_image")
  imageFindingsTotal   Int      @default(0) @map("image_findings_total")
  imageFindingsMissing Int      @default(0) @map("image_findings_missing")
  imageFindingsIssues  Int      @default(0) @map("image_findings_issues")
  createdAt            DateTime @default(now()) @map("created_at")

  job           SeoCrawlJob            @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)
  issues        SeoCrawlIssue[]
  outboundLinks SeoCrawlPageLink[]     @relation("SeoCrawlPageLink_source")
  inboundLinks  SeoCrawlPageLink[]     @relation("SeoCrawlPageLink_target")
  imageFindings SeoCrawlImageFinding[]

  @@unique([crawlJobId, url])
  @@index([crawlJobId, statusCode])
  @@index([crawlJobId, errorCount(sort: Desc)])
  @@map("seo_crawl_url_result")
}

model SeoCrawlIssue {
  id             String                @id @default(cuid())
  crawlJobId     String                @map("crawl_job_id")
  urlResultId    String                @map("url_result_id")
  code           String
  severity       SeoCrawlIssueSeverity
  category       SeoCrawlIssueCategory
  message        String
  recommendation String?
  context        Json?
  createdAt      DateTime              @default(now()) @map("created_at")

  job    SeoCrawlJob       @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)
  result SeoCrawlUrlResult @relation(fields: [urlResultId], references: [id], onDelete: Cascade)

  @@index([crawlJobId, severity])
  @@index([crawlJobId, category])
  @@index([crawlJobId, code])
  @@map("seo_crawl_issue")
}

/// Edge of the per-crawl link graph. One row per <a href> kept (capped per
/// source page in the runner). `targetResultId` is back-filled once we know
/// the destination was crawled in the same job, enabling fast orphan /
/// inbound queries via index lookups instead of URL string joins.
model SeoCrawlPageLink {
  id             String   @id @default(cuid())
  crawlJobId     String   @map("crawl_job_id")
  sourceResultId String   @map("source_result_id")
  targetUrl      String   @map("target_url")
  targetPathname String?  @map("target_pathname")
  targetResultId String?  @map("target_result_id")
  anchorText     String?  @map("anchor_text")
  rel            String?
  nofollow       Boolean  @default(false)
  isInternal     Boolean  @default(true) @map("is_internal")
  createdAt      DateTime @default(now()) @map("created_at")

  source SeoCrawlUrlResult  @relation("SeoCrawlPageLink_source", fields: [sourceResultId], references: [id], onDelete: Cascade)
  target SeoCrawlUrlResult? @relation("SeoCrawlPageLink_target", fields: [targetResultId], references: [id], onDelete: SetNull)

  @@index([crawlJobId, sourceResultId])
  @@index([crawlJobId, targetResultId])
  @@index([crawlJobId, targetUrl])
  @@index([crawlJobId, isInternal])
  @@map("seo_crawl_page_link")
}

/// One row per <img> emitted by the crawler (capped per page in the runner).
/// Powers the dashboard Images tab — aggregate counts come from the job-level
/// rollups on SeoCrawlJob, and per-page drill-downs read this table directly.
model SeoCrawlImageFinding {
  id          String          @id @default(cuid())
  crawlJobId  String          @map("crawl_job_id")
  urlResultId String          @map("url_result_id")
  src         String
  filename    String?
  alt         String?
  hasAlt      Boolean         @default(false) @map("has_alt")
  altQuality  ImageAltQuality @map("alt_quality")
  widthAttr   Int?            @map("width_attr")
  heightAttr  Int?            @map("height_attr")
  loadingAttr String?         @map("loading_attr")
  isOgImage   Boolean         @default(false) @map("is_og_image")
  inSitemap   Boolean         @default(false) @map("in_sitemap")
  aboveFold   Boolean         @default(false) @map("above_fold")
  flags       Json            @default("[]")
  createdAt   DateTime        @default(now()) @map("created_at")

  job    SeoCrawlJob       @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)
  result SeoCrawlUrlResult @relation(fields: [urlResultId], references: [id], onDelete: Cascade)

  @@index([crawlJobId])
  @@index([crawlJobId, altQuality])
  @@index([crawlJobId, hasAlt])
  @@index([urlResultId])
  @@map("seo_crawl_image_finding")
}

// ─── Translation Jobs ─────────────────────────────────────

enum TranslationJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  REVIEW_REQUIRED
  APPROVED
}

model TranslationJob {
