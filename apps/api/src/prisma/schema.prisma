  siteId         String   @unique @map("site_id")
  businessType   String   @default("Hotel") @map("business_type")
  businessName   String?  @map("business_name")
  description    String?
  streetAddress  String?  @map("street_address")
  city           String?
  region         String?
  postalCode     String?  @map("postal_code")
  country        String?
  telephone      String?
  email          String?
  starRating     Int?     @map("star_rating")
  priceRange     String?  @map("price_range")
  checkInTime    String?  @map("check_in_time")
  checkOutTime   String?  @map("check_out_time")
  amenities      Json?
