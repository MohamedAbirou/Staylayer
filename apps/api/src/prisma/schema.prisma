  siteId           String                   @map("site_id")
  type             OperationalAlertType
  severity         OperationalAlertSeverity @default(WARNING)
  status           OperationalAlertStatus   @default(OPEN)
  fingerprint      String
  message          String
  metadata         Json?
  firstTriggeredAt DateTime                 @default(now()) @map("first_triggered_at")
  lastTriggeredAt  DateTime                 @default(now()) @map("last_triggered_at")
  resolvedAt       DateTime?                @map("resolved_at")
