// ─── Google Search Console (Phase B.1) ────────────────────

enum SearchConsoleConnectionStatus {
  ACTIVE
  REVOKED
  ERROR
  EXPIRED
}

enum SearchConsoleSyncJobType {
  DAILY
  ON_DEMAND
  SITEMAP_SUBMIT
  URL_INSPECTION
}

enum SearchConsoleSyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

/// One row per (site, Google account). Holds the encrypted refresh token and
/// the Search Console property URL (siteUrl) to use for API calls.
model SearchConsoleConnection {
  id                    String                        @id @default(cuid())
  siteId                String                        @unique @map("site_id")
  status                SearchConsoleConnectionStatus @default(ACTIVE)
  googleAccountEmail    String?                       @map("google_account_email")
  googleAccountSubject  String?                       @map("google_account_subject")
  /// Search Console "siteUrl" property — e.g. "https://example.com/" or "sc-domain:example.com".
  propertyUrl           String                        @map("property_url")
  scope                 String
  encryptedRefreshToken String                        @map("encrypted_refresh_token") @db.Text
  /// Cached access token + expiry, refreshed lazily.
  accessTokenCache      String?                       @map("access_token_cache") @db.Text
  accessTokenExpiresAt  DateTime?                     @map("access_token_expires_at")
  lastSyncedAt          DateTime?                     @map("last_synced_at")
  lastSuccessfulSyncAt  DateTime?                     @map("last_successful_sync_at")
  lastError             String?                       @map("last_error")
  consecutiveFailures   Int                           @default(0) @map("consecutive_failures")
  connectedByUserId     String?                       @map("connected_by_user_id")
  createdAt             DateTime                      @default(now()) @map("created_at")
  updatedAt             DateTime                      @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([lastSyncedAt])
  @@map("search_console_connection")
}

/// Sync job history (daily cron + on-demand). One row per attempted run.
model SearchConsoleSyncJob {
  id             String                     @id @default(cuid())
  siteId         String                     @map("site_id")
  type           SearchConsoleSyncJobType
  status         SearchConsoleSyncJobStatus @default(PENDING)
  rangeStart     DateTime?                  @map("range_start")
  rangeEnd       DateTime?                  @map("range_end")
  pagesSynced    Int                        @default(0) @map("pages_synced")
  queriesSynced  Int                        @default(0) @map("queries_synced")
  sitemapsSynced Int                        @default(0) @map("sitemaps_synced")
  inspectionsRun Int                        @default(0) @map("inspections_run")
  failureReason  String?                    @map("failure_reason")
  startedAt      DateTime?                  @map("started_at")
  completedAt    DateTime?                  @map("completed_at")
  triggeredBy    String?                    @map("triggered_by")
  createdAt      DateTime                   @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
  @@index([status])
  @@map("search_console_sync_job")
}

/// Daily per-page performance roll-up. Unique on (siteId, date, page).
