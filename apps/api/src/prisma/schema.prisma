// ─── URL Redirects ────────────────────────────────────────

model Redirect {
  id         String   @id @default(cuid())
  siteId     String   @map("site_id")
  fromPath   String   @map("from_path")
  toPath     String   @map("to_path")
  statusCode Int      @default(301) @map("status_code")
  locale     String?
  reason     String?
  permanent  Boolean  @default(true)
  enabled    Boolean  @default(true)
  /// Origin of the rule. One of MANUAL | CSV_IMPORT | SLUG_CHANGE | PAGE_DELETE.
  source     String   @default("MANUAL")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, fromPath, locale])
  @@index([siteId, enabled])
  @@index([siteId, fromPath])
  @@index([siteId, source])
  @@map("redirects")
}

