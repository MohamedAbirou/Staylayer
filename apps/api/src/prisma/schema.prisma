  pageId      String?               @map("page_id")
  details     Json                  @default("{}")
  dismissedAt DateTime?             @map("dismissed_at")
  dismissedBy String?               @map("dismissed_by")
  createdAt   DateTime              @default(now()) @map("created_at")

  scan HreflangScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  site Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([siteId, type])
  @@index([siteId, slug])
  @@map("hreflang_issues")
}

// ─── Bing Webmaster Tools (Phase B.2) ──────────────────────

enum BingWebmasterConnectionStatus {
  ACTIVE
  REVOKED
  ERROR
}

enum BingSyncJobType {
  DAILY
  ON_DEMAND
  SITEMAP_SUBMIT
}

enum BingSyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum BingCrawlIssueSeverity {
  ERROR
  WARNING
  INFO
}

/// One row per (site, Bing Webmaster API key). Stores the encrypted API key
/// and the Bing-verified site URL (`siteUrl`) used as the API parameter.
model BingWebmasterConnection {
  id                   String                        @id @default(cuid())
  siteId               String                        @unique @map("site_id")
  status               BingWebmasterConnectionStatus @default(ACTIVE)
  /// The Bing-verified site, e.g. `https://example.com`. Used as the
  /// `siteUrl` parameter on all Bing Webmaster API calls.
  propertyUrl          String                        @map("property_url")
  /// AES-256-GCM ciphertext of the user-pasted API key.
  encryptedApiKey      String                        @map("encrypted_api_key") @db.Text
  /// First 4 + last 4 chars of the key with `***` in the middle, for UI.
  apiKeyFingerprint    String?                       @map("api_key_fingerprint")
  lastSyncedAt         DateTime?                     @map("last_synced_at")
  lastSuccessfulSyncAt DateTime?                     @map("last_successful_sync_at")
  lastError            String?                       @map("last_error")
  consecutiveFailures  Int                           @default(0) @map("consecutive_failures")
  connectedByUserId    String?                       @map("connected_by_user_id")
  createdAt            DateTime                      @default(now()) @map("created_at")
  updatedAt            DateTime                      @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([lastSyncedAt])
  @@map("bing_webmaster_connection")
}

model BingSyncJob {
  id                String            @id @default(cuid())
  siteId            String            @map("site_id")
  type              BingSyncJobType
  status            BingSyncJobStatus @default(PENDING)
  rangeStart        DateTime?         @map("range_start")
  rangeEnd          DateTime?         @map("range_end")
  pagesSynced       Int               @default(0) @map("pages_synced")
  queriesSynced     Int               @default(0) @map("queries_synced")
  sitemapsSynced    Int               @default(0) @map("sitemaps_synced")
  crawlIssuesSynced Int               @default(0) @map("crawl_issues_synced")
  failureReason     String?           @map("failure_reason")
  startedAt         DateTime?         @map("started_at")
  completedAt       DateTime?         @map("completed_at")
  triggeredBy       String?           @map("triggered_by")
  createdAt         DateTime          @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
  @@index([status])
  @@map("bing_sync_job")
}

/// Daily per-page performance roll-up from Bing GetPageStats.
model BingPagePerformance {
  id          String   @id @default(cuid())
  siteId      String   @map("site_id")
  date        DateTime @db.Date
  page        String
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, date, page])
  @@index([siteId, date])
  @@index([siteId, page])
  @@map("bing_page_performance")
}

/// Daily per-query performance roll-up from Bing GetQueryStats (+ optional page).
model BingQueryPerformance {
  id          String   @id @default(cuid())
  siteId      String   @map("site_id")
  date        DateTime @db.Date
  query       String
  /// Optional page dimension. Empty string `""` means "all pages aggregate"
  /// — Postgres treats NULL as distinct in unique indexes, so we use the
  /// empty-string sentinel to make `@@unique([siteId, date, query, page])`
  /// enforce upsert idempotency.
  page        String   @default("")
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, date, query, page])
  @@index([siteId, date])
  @@index([siteId, query])
  @@map("bing_query_performance")
}

model BingSitemap {
  id             String    @id @default(cuid())
  siteId         String    @map("site_id")
  sitemapUrl     String    @map("sitemap_url")
  /// Free-form Bing-reported status (e.g. `Submitted`, `PendingDownload`).
  status         String?
  lastSubmitted  DateTime? @map("last_submitted")
  lastDownloaded DateTime? @map("last_downloaded")
  errors         Int       @default(0)
  warnings       Int       @default(0)
  urlCount       Int       @default(0) @map("url_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, sitemapUrl])
  @@index([siteId])
  @@map("bing_sitemap")
}

/// One row per crawl issue detected by Bing for a given (site, URL, issue code).
model BingCrawlIssue {
  id              String                 @id @default(cuid())
  siteId          String                 @map("site_id")
  url             String
  /// Bing's numeric or string issue code. We store as string for portability.
  issueCode       String                 @map("issue_code")
  /// Bing's human-readable category (e.g. `Server errors`).
  category        String?
  severity        BingCrawlIssueSeverity @default(WARNING)
  httpCode        Int?                   @map("http_code")
  firstDetectedAt DateTime               @map("first_detected_at")
  lastSeenAt      DateTime               @map("last_seen_at")
  resolvedAt      DateTime?              @map("resolved_at")
  details         Json?
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, url, issueCode])
  @@index([siteId, lastSeenAt])
  @@index([siteId, severity])
  @@map("bing_crawl_issue")
}

/// Per-site backlink snapshot from Bing GetLinkCounts.
model BingLinkSummary {
  id         String   @id @default(cuid())
  siteId     String   @unique @map("site_id")
  totalLinks Int      @default(0) @map("total_links")
  fetchedAt  DateTime @map("fetched_at")
  /// Top referring domains (top 50) — array of `{ domain, count }`.
  topDomains Json?    @map("top_domains")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("bing_link_summary")
}

// ─── Phase E.2: AI Citation Readiness Audit ─────────────────
//
// Per (site, slug, locale) readiness score for citation by LLM answer
// engines (ChatGPT, Perplexity, Claude, Gemini, etc.). Scores are heuristic
// — not predictions — and re-computed on demand or after publish.
model AiCitationAudit {
  id     String @id @default(cuid())
  siteId String @map("site_id")
  slug   String
  locale String

  /// Overall readiness score 0–100.
  score Int
  /// Letter grade derived from score (A/B/C/D/F).
  grade String

  /// Number of distinct entity facts detected (name, address, prices, etc.).
  entityFactCount  Int  @default(0) @map("entity_fact_count")
  /// Number of answer-ready sections (Q&A patterns, definitional sentences).
  answerReadyCount Int  @default(0) @map("answer_ready_count")
  /// Days since the source page was last updated; null if unknown.
  freshnessDays    Int? @map("freshness_days")

  /// Array of `{ code, severity, message, snippet?, locator? }` items.
  findings Json
  /// `{ entityFacts, answerReady, freshness, robots, structuredData }`.
  signals  Json

  analyzedAt DateTime @default(now()) @map("analyzed_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug, locale])
  @@index([siteId, score])
  @@index([siteId, analyzedAt])
  @@map("ai_citation_audits")
}

// ─── Phase E.3: Scheduled SEO audits + history + in-app alerts ──────────

enum SeoAuditScheduleCadence {
  OFF
  DAILY
  WEEKLY
}

enum SeoAuditRunKind {
  SCHEDULED
  MANUAL
}

enum SeoAuditRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

/// Per-site cadence configuration for automated SEO audit runs.
model SeoAuditSchedule {
  id        String                  @id @default(cuid())
  siteId    String                  @unique @map("site_id")
  cadence   SeoAuditScheduleCadence @default(WEEKLY)
  enabled   Boolean                 @default(true)
  /// 0–23 UTC; used as the hour-of-day the next run is scheduled at.
  hourUtc   Int                     @default(3) @map("hour_utc")
  /// 0 = Sunday … 6 = Saturday. Only used when cadence = WEEKLY.
  dayOfWeek Int?                    @map("day_of_week")

  lastRunAt DateTime? @map("last_run_at")
  nextRunAt DateTime? @map("next_run_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([enabled, nextRunAt])
  @@map("seo_audit_schedules")
}

/// One row per audit run (scheduled or manually triggered). Aggregates the
/// per-page snapshots recorded under `SeoAuditSnapshot`.
model SeoAuditRun {
  id            String            @id @default(cuid())
  siteId        String            @map("site_id")
  kind          SeoAuditRunKind   @default(SCHEDULED)
  status        SeoAuditRunStatus @default(RUNNING)
  startedAt     DateTime          @default(now()) @map("started_at")
  finishedAt    DateTime?         @map("finished_at")
  durationMs    Int?              @map("duration_ms")
  pagesAudited  Int               @default(0) @map("pages_audited")
  alertsCreated Int               @default(0) @map("alerts_created")
  /// Average AI-citation score across pages audited in this run.
  averageScore  Int?              @map("average_score")
  /// First error message if `status = FAILED`.
  error         String?
  triggeredBy   String?           @map("triggered_by")

  site      Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  snapshots SeoAuditSnapshot[]

  @@index([siteId, startedAt])
  @@index([status])
  @@map("seo_audit_runs")
}

/// Per-page snapshot recorded by an audit run. Used to render score-history
/// sparklines and to diff against previous runs to surface regressions.
model SeoAuditSnapshot {
  id               String   @id @default(cuid())
  runId            String   @map("run_id")
  siteId           String   @map("site_id")
  slug             String
  locale           String
  score            Int
  grade            String
  entityFactCount  Int      @default(0) @map("entity_fact_count")
  answerReadyCount Int      @default(0) @map("answer_ready_count")
  findingsCount    Int      @default(0) @map("findings_count")
  allowsCitation   Boolean  @default(true) @map("allows_citation")
  recordedAt       DateTime @default(now()) @map("recorded_at")

  run  SeoAuditRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  site Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, slug, locale, recordedAt])
  @@index([runId])
  @@map("seo_audit_snapshots")
}

// ─── Phase E.4: Bulk SEO audit workflow (tasks + assignment) ────────────

enum SeoAuditTaskStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum SeoAuditTaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SeoAuditTaskSource {
  ALERT
  MANUAL
}

/// Triage item layered on top of audit findings. Each task corresponds to a
/// single page (slug + locale) and may optionally link to the originating
/// `OperationalAlert`. `assigneeUserId` is nullable — unassigned is valid.
model SeoAuditTask {
  id              String               @id @default(cuid())
  siteId          String               @map("site_id")
  sourceAlertId   String?              @unique @map("source_alert_id")
  source          SeoAuditTaskSource   @default(MANUAL)
  slug            String
  locale          String
  title           String
  description     String?
  status          SeoAuditTaskStatus   @default(OPEN)
  priority        SeoAuditTaskPriority @default(MEDIUM)
  /// Tenant-scoped assignee. Null means unassigned. Validated against
  /// TenantMembership at the service layer.
  assigneeUserId  String?              @map("assignee_user_id")
  createdByUserId String?              @map("created_by_user_id")
  resolvedAt      DateTime?            @map("resolved_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  site        Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sourceAlert OperationalAlert? @relation("SeoAuditTaskAlert", fields: [sourceAlertId], references: [id], onDelete: SetNull)
  assignee    User?             @relation("SeoAuditTaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  createdBy   User?             @relation("SeoAuditTaskCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([siteId, status])
  @@index([siteId, assigneeUserId, status])
  @@index([siteId, priority, status])
  @@index([siteId, slug, locale])
  @@map("seo_audit_tasks")
}
