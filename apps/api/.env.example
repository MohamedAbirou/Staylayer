# ═══════════════════════════════════════════════════════════
# StayLayer CMS — NestJS API (.env)
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────
# Full PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/staylayer_cms?schema=public"

# ─── JWT (RS256 asymmetric) ────────────────────────────────
# Generate with:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in private.pem -out public.pem
# Paste the full PEM content — use \n for newlines in a single-line string
# OR use the multi-line form shown below.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvA...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIj...\n-----END PUBLIC KEY-----"

# Access token TTL (default: 15 minutes)
JWT_ACCESS_EXPIRES_IN="15m"
# Refresh token TTL (default: 30 days)
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
THROTTLE_TTL=900000
THROTTLE_LIMIT=200

# CORS (comma-separated origins)
CORS_ORIGINS="http://localhost:5173,http://localhost:4174,http://localhost:3000,http://localhost:3002"

# Shared Website runtime
WEBSITE_APP_ORIGIN="http://localhost:3000"
WEBSITE_RUNTIME_SECRET="your-website-runtime-secret-here"
PREVIEW_TOKEN_SECRET="your-preview-token-secret-here"
PLATFORM_ROOT_DOMAIN="staylayer.localhost"
WEBSITE_VERCEL_PROJECT_ID=""
WEBSITE_VERCEL_PROJECT_NAME=""
# Current Vercel dashboard DNS recommendations for the shared Website project.
# Vercel's public domain-config API can lag behind these generated dashboard values.
WEBSITE_VERCEL_RECOMMENDED_APEX_IPV4=""
WEBSITE_VERCEL_RECOMMENDED_CNAME=""

# Runtime invalidation
# WEBSITE_APP_ORIGIN is preferred. REVALIDATION_URL is an optional fallback for
# direct route targeting when the website origin is not available.
REVALIDATION_URL="http://localhost:3000/api/revalidate"
REVALIDATE_SECRET="your-website-runtime-secret-here"

# Public app origins used by host resolution and reserved-host redirects
MARKETING_APP_ORIGIN="http://localhost:3002"
DASHBOARD_APP_ORIGIN="http://localhost:5173"

# Optional shared runtime cache
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Legacy dedicated deployment settings
# These are no longer required for the shared public Website runtime.
DEPLOYMENTS_CMS_API_URL="https://api.staylayer.com"
DEPLOYMENTS_REVALIDATE_SECRET="your-dedicated-site-revalidate-secret"
DEPLOYMENTS_PROJECT_NAME_PREFIX="staylayer-site"
DEPLOYMENTS_WEBSITE_FRAMEWORK="nextjs"
DEPLOYMENTS_WEBSITE_ROOT_DIRECTORY="apps/website"
DEPLOYMENTS_WEBSITE_BUILD_COMMAND="cd ../.. && corepack prepare pnpm@10.33.4 --activate && pnpm --filter @staylayer/website build"
DEPLOYMENTS_WEBSITE_OUTPUT_DIRECTORY=".next"
DEPLOYMENTS_WEBSITE_INSTALL_COMMAND="cd ../.. && corepack prepare pnpm@10.33.4 --activate && pnpm install --registry https://registry.npmjs.org --fetch-timeout=60000 --fetch-retries=3 --no-frozen-lockfile"
DEPLOYMENTS_VERCEL_ACCESS_TOKEN=""
DEPLOYMENTS_VERCEL_TEAM_ID=""
# Optional alternative to DEPLOYMENTS_VERCEL_TEAM_ID
DEPLOYMENTS_VERCEL_TEAM_SLUG=""
DEPLOYMENTS_VERCEL_GIT_PROVIDER="github"
DEPLOYMENTS_VERCEL_GIT_REPO="ORG/staylayer-cms"
DEPLOYMENTS_VERCEL_GIT_REPO_ID=""
DEPLOYMENTS_VERCEL_PRODUCTION_BRANCH="main"

# Domain verification
# Set to false only when you intentionally want to bypass external DNS/HTTPS checks in local work.
DOMAIN_VERIFICATION_ENABLED="true"

# Inquiry email delivery
# For local Mailpit testing, use:
#   SMTP_HOST=127.0.0.1
#   SMTP_PORT=1025
#   SMTP_SECURE=false
#   INQUIRY_EMAIL_FROM=hello@local.staylayer.test
# For production on platforms that block SMTP egress, prefer an HTTP provider such as Resend.
# When RESEND_API_KEY is set, the app will use Resend instead of SMTP.
# RESEND_API_URL is optional unless you are using a proxy or an alternative endpoint.
# SMTP_USER and SMTP_PASS are optional for local sinks such as Mailpit.
RESEND_API_KEY=""
RESEND_API_URL="https://api.resend.com"
SMTP_HOST=""
SMTP_PORT="1025"
SMTP_SECURE="false"
# Defaults to ipv4first to avoid hosted-runtime SMTP failures when outbound IPv6 is unavailable.
# Set to verbatim only if you explicitly want the runtime DNS order.
SMTP_DNS_RESULT_ORDER="ipv4first"
SMTP_USER=""
SMTP_PASS=""
INQUIRY_EMAIL_FROM=""
TRANSACTIONAL_EMAIL_FROM=""
MARKETING_CONTACT_EMAIL=""
MARKETING_APP_URL="http://localhost:3002"
DASHBOARD_APP_URL="http://localhost:5173"

# Billing (optional unless you are testing checkout, billing portal, or webhooks)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# Stripe product Price IDs (create Prices in the Stripe dashboard or via the Stripe CLI
# and paste their `price_...` identifiers here). These map to the plans in
# `apps/api/src/billing/billing-plans.ts`.
STRIPE_PRICE_STARTER_STAY=""
STRIPE_PRICE_BOUTIQUE_GROWTH=""
STRIPE_PRICE_PORTFOLIO=""

# ── Google Search Console (Phase B.1) ────────────────────────────
# Google OAuth 2.0 Client (type: Web application). Create at
# https://console.cloud.google.com/apis/credentials and add the dashboard
# callback (SEARCH_CONSOLE_OAUTH_REDIRECT_URI) to "Authorized redirect URIs".
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
# Must point at the dashboard origin /seo/search-console/callback (e.g.
# http://localhost:5173/seo/search-console/callback in dev).
SEARCH_CONSOLE_OAUTH_REDIRECT_URI="http://localhost:5173/seo/search-console/callback"
# Optional dedicated HMAC secret for the OAuth `state` parameter. If unset,
# falls back to SEO_TOKEN_ENCRYPTION_KEY.
SEARCH_CONSOLE_OAUTH_STATE_SECRET=""
# AES-256-GCM key (32 bytes, base64-encoded) used to encrypt stored Google
# refresh tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SEO_TOKEN_ENCRYPTION_KEY=""
# Set to "true" to disable the daily Search Console sync cron (rarely needed).
SEARCH_CONSOLE_CRON_DISABLED=""

# Optional cron kill-switches for advanced SEO background syncs.
SEO_AUDIT_CRON_DISABLED=""
BING_WEBMASTER_CRON_DISABLED=""

# -- PageSpeed Insights + CrUX (Phase B.3) ------------------------
# Single platform-wide API key with PageSpeed Insights API and
# Chrome UX Report API enabled. Plan-based monthly limits gate usage
# per tenant.
PSI_API_KEY=""
# Optional cache window override for PSI audits, in hours. Default: 6.
PSI_CACHE_MAX_AGE_HOURS=""
# Optional cache window override for CrUX records, in hours. Default: 24.
CRUX_CACHE_MAX_AGE_HOURS=""
