# ═══════════════════════════════════════════════════════════
# MyAllocator CMS — NestJS API (.env)
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────
# Full PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/myallocator_cms?schema=public"

# ─── JWT (RS256 asymmetric) ────────────────────────────────
# Generate with:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in private.pem -out public.pem
# Paste the full PEM content — use \n for newlines in a single-line string
# OR use the multi-line form shown below.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvA...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIj...\n-----END PUBLIC KEY-----"

# Access token TTL (default: 15 minutes)
JWT_ACCESS_EXPIRES_IN="15m"
# Refresh token TTL (default: 30 days)
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
THROTTLE_TTL=900000
THROTTLE_LIMIT=200

# CORS (comma-separated origins)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ISR Revalidation
REVALIDATION_URL="http://localhost:3000/api/revalidate"
REVALIDATE_SECRET="your-revalidation-secret-here"

# Dedicated site deployments (Vercel)
# Leave these unset in local development unless you are exercising phase-07 provisioning.
DEPLOYMENTS_CMS_API_URL="https://api.myallocator.com"
DEPLOYMENTS_REVALIDATE_SECRET="your-dedicated-site-revalidate-secret"
DEPLOYMENTS_PROJECT_NAME_PREFIX="myallocator-site"
DEPLOYMENTS_WEBSITE_FRAMEWORK="nextjs"
DEPLOYMENTS_WEBSITE_ROOT_DIRECTORY="apps/website"
DEPLOYMENTS_WEBSITE_BUILD_COMMAND="cd ../.. && corepack prepare pnpm@10.33.4 --activate && pnpm --filter @myallocator/website build"
DEPLOYMENTS_WEBSITE_OUTPUT_DIRECTORY=".next"
DEPLOYMENTS_WEBSITE_INSTALL_COMMAND="cd ../.. && corepack prepare pnpm@10.33.4 --activate && pnpm install --registry https://registry.npmjs.org --fetch-timeout=60000 --fetch-retries=3 --no-frozen-lockfile"
DEPLOYMENTS_VERCEL_ACCESS_TOKEN=""
DEPLOYMENTS_VERCEL_TEAM_ID=""
# Optional alternative to DEPLOYMENTS_VERCEL_TEAM_ID
DEPLOYMENTS_VERCEL_TEAM_SLUG=""
DEPLOYMENTS_VERCEL_GIT_PROVIDER="github"
DEPLOYMENTS_VERCEL_GIT_REPO="ORG/myallocator-cms"
DEPLOYMENTS_VERCEL_GIT_REPO_ID=""
DEPLOYMENTS_VERCEL_PRODUCTION_BRANCH="main"

# Domain verification
# Set to false only when you intentionally want to bypass external DNS/HTTPS checks in local work.
DOMAIN_VERIFICATION_ENABLED="true"

# Inquiry email delivery
# For local Mailpit testing, use:
#   SMTP_HOST=127.0.0.1
#   SMTP_PORT=1025
#   SMTP_SECURE=false
#   INQUIRY_EMAIL_FROM=hello@local.myallocator.test
# SMTP_USER and SMTP_PASS are optional for local sinks such as Mailpit.
SMTP_HOST=""
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
INQUIRY_EMAIL_FROM=""

# Billing (optional unless you are testing checkout, billing portal, or webhooks)
STRIPE_SECRET_KEY=""
