{
  "info": {
    "name": "MyAllocator CMS API",
    "_postman_id": "ma-cms-api-v1",
    "description": "Full API collection for the MyAllocator CMS backend.\n\nSetup:\n1. Set the `baseUrl` collection variable (default: http://localhost:3001)\n2. Call **POST /auth/login** — the test script automatically copies the accessToken into the collection variable.\n3. All subsequent requests use `{{accessToken}}` automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('DB is up', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.equal('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/login (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@myallocator.com\",\n  \"password\": \"Admin123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns accessToken', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /auth/login (super-admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@myallocator.com\",\n  \"password\": \"SuperAdmin123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.accessToken) pm.collectionVariables.set('accessToken', body.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /auth/login (editor)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"editor@myallocator.com\",\n  \"password\": \"Editor123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "POST /auth/login (wrong password → 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@myallocator.com\",\n  \"password\": \"WrongPassword!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /auth/refresh",
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "none" },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "The refresh token is sent automatically via httpOnly cookie set by /auth/login. Postman forwards cookies within the same session."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.accessToken) pm.collectionVariables.set('accessToken', body.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "none" },
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('accessToken', '');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "description": "All endpoints require the PLATFORM_OWNER platform role.",
      "item": [
        {
          "name": "GET /users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /users",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"neweditor@myallocator.com\",\n  \"password\": \"NewEditor123!\",\n  \"role\": \"EDITOR\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body.id) pm.collectionVariables.set('userId', body.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "PATCH /users/:id",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"ADMIN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            },
            "description": "Replace {{userId}} with an actual user ID, or run POST /users first — the test script saves the new user's id into {{userId}}."
          }
        },
        {
          "name": "DELETE /users/:id",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 204', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Pages",
      "item": [
        {
          "name": "GET /pages (all, authenticated)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/pages?locale=en&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["pages"],
              "query": [
                { "key": "locale", "value": "en" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /pages (published only)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/pages?locale=en&published=true",
              "host": ["{{baseUrl}}"],
              "path": ["pages"],
              "query": [
                { "key": "locale", "value": "en" },
                { "key": "published", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "GET /pages/home (authenticated)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/pages/home?locale=en",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "home"],
              "query": [{ "key": "locale", "value": "en" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has puckData', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.puckData).to.be.an('object');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /pages/home (public — no auth)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pages/home?locale=en&published=true",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "home"],
              "query": [
                { "key": "locale", "value": "en" },
                { "key": "published", "value": "true" }
              ]
            },
            "description": "Public access is allowed only when ?published=true is passed with no auth header."
          }
        },
        {
          "name": "POST /pages",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"about\",\n  \"locale\": \"en\",\n  \"title\": \"About Us\",\n  \"puckData\": {\n    \"content\": [\n      {\n        \"type\": \"HeroSection\",\n        \"props\": {\n          \"id\": \"about-hero\",\n          \"headline\": \"About myallocator\",\n          \"subheadline\": \"Our story.\",\n          \"ctaLabel\": \"Contact Us\",\n          \"ctaHref\": \"/contact\",\n          \"imageUrl\": \"\"\n        }\n      }\n    ],\n    \"root\": { \"title\": \"About\" }\n  },\n  \"seoTitle\": \"About Us — myallocator\",\n  \"seoDescription\": \"Learn about the team behind myallocator.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/pages",
              "host": ["{{baseUrl}}"],
              "path": ["pages"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "PUT /pages/about",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"About Us (Updated)\",\n  \"seoTitle\": \"About myallocator — Channel Manager\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/pages/about?locale=en",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "about"],
              "query": [{ "key": "locale", "value": "en" }]
            }
          }
        },
        {
          "name": "GET /pages/about/preview",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/pages/about/preview?locale=en",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "about", "preview"],
              "query": [{ "key": "locale", "value": "en" }]
            }
          }
        },
        {
          "name": "POST /pages/about/publish",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "none" },
            "url": {
              "raw": "{{baseUrl}}/pages/about/publish?locale=en",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "about", "publish"],
              "query": [{ "key": "locale", "value": "en" }]
            }
          }
        },
        {
          "name": "POST /pages/about/unpublish",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "none" },
            "url": {
              "raw": "{{baseUrl}}/pages/about/unpublish?locale=en",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "about", "unpublish"],
              "query": [{ "key": "locale", "value": "en" }]
            }
          }
        },
        {
          "name": "DELETE /pages/about",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/pages/about?locale=en",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "about"],
              "query": [{ "key": "locale", "value": "en" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 204', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Versions",
      "item": [
        {
          "name": "GET /pages/home/versions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/pages/home/versions?locale=en&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "home", "versions"],
              "query": [
                { "key": "locale", "value": "en" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.data && body.data[0]) pm.collectionVariables.set('versionId', body.data[0].id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /pages/home/versions/:id/restore",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "none" },
            "url": {
              "raw": "{{baseUrl}}/pages/home/versions/{{versionId}}/restore?locale=en",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "home", "versions", "{{versionId}}", "restore"],
              "query": [{ "key": "locale", "value": "en" }]
            },
            "description": "Run GET /pages/home/versions first — the test script saves the first version's id into {{versionId}}."
          }
        }
      ]
    }
  ]
}
