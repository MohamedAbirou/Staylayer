{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "rootDir": "../..",
    "paths": {
      "@staylayer/puck-components": [
        "../../packages/puck-components/src/index.ts"
      ],
      "@staylayer/puck-components/*": ["../../packages/puck-components/src/*"]
    },
    "outDir": "./dist",
    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
