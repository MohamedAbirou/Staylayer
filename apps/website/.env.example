# Brand
NEXT_PUBLIC_BRAND_NAME=MyAllocator
NEXT_PUBLIC_BRAND_URL=http://localhost:3000
NEXT_PUBLIC_PRICE=$9

# CMS API (NestJS backend URL — used by the Next.js app at runtime)
#   Local dev:   http://localhost:4000
#   Production:  https://api.yourdomain.com
NEXT_PUBLIC_CMS_API_URL=http://localhost:4000
CMS_API_URL=http://localhost:4000

# Dedicated site identity
# NEXT_PUBLIC_SITE_ID is required for client-side public settings fetches.
SITE_ID=
NEXT_PUBLIC_SITE_ID=
SITE_SLUG=
PRIMARY_LOCALE=en
ENABLED_LOCALES=en

# Analytics (optional)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_CLARITY_ID=

# ISR Revalidation (shared secret with the NestJS API — NOT a NEXT_PUBLIC_ variable)
REVALIDATE_SECRET=your-revalidation-secret-here
# Backwards-compatible alias accepted by the ISR route
REVALIDATION_SECRET=your-revalidation-secret-here

# ─── Migration script (node scripts/migrate-pages.js) ─────────────────────────
# The script uses these to auto-login and seed pages. Must be ADMIN or SUPER_ADMIN.
# Run  pnpm --filter @myallocator/api db:seed  first to create default users.
CMS_ADMIN_EMAIL=superadmin@myallocator.com
CMS_ADMIN_PASSWORD=SuperAdmin123!
# CMS_SEED_TOKEN=   # Optional: use a pre-obtained JWT instead of email/password