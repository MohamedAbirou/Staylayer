# Shared Website runtime
# Public/runtime API base URL used by the Website server components and
# middleware. Prefer API_INTERNAL_URL when the Website can reach the API over a
# private network.
API_INTERNAL_URL=http://localhost:4000
API_URL=http://localhost:4000

# Shared secret expected by the API runtime endpoints and the Website
# revalidation route.
WEBSITE_RUNTIME_SECRET=your-website-runtime-secret-here

# Used by /api/preview to validate signed preview tokens issued by the API.
PREVIEW_TOKEN_SECRET=your-preview-token-secret-here

# Host routing guardrails used by middleware before tenant resolution.
# PLATFORM_ROOT_DOMAIN is the SaaS root; Marketing and Dashboard stay on their
# own deployments and should not render customer pages through Website.
PLATFORM_ROOT_DOMAIN=staylayer.localhost
MARKETING_APP_ORIGIN=http://localhost:3002
DASHBOARD_APP_ORIGIN=http://localhost:5173

# Optional fallback alias accepted by /api/revalidate.
REVALIDATE_SECRET=your-website-runtime-secret-here

# Optional comma-separated allowlist for Next/Image remote hosts.
PUBLIC_IMAGE_HOSTS=

# Optional branding defaults for any remaining brand helpers.
NEXT_PUBLIC_BRAND_NAME=MyAllocator
NEXT_PUBLIC_BRAND_URL=http://localhost:3000

# ─── Migration script (node scripts/migrate-pages.js) ─────────────────────────
# The script uses these to auto-login and seed pages. Must be an OWNER or ADMIN workspace member.
# Run  pnpm --filter @myallocator/api db:seed  first to create default users.
CMS_ADMIN_EMAIL=owner@myallocator.com
CMS_ADMIN_PASSWORD=Owner123!
# CMS_SEED_TOKEN=   # Optional: use a pre-obtained JWT instead of email/password