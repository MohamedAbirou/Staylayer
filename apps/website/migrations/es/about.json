      {
        "type": "Paragraph",
        "props": {
          "id": "Paragraph-643e2dbc-2f37-4b71-aba8-79265b9efa77",
          "size": "xl",
          "text": "MyAllocator es el software integral de gestión de alquileres vacacionales que ayuda a los anfitriones y a los gestores inmobiliarios a ganar más, trabajar menos y deleitar a los huéspedes. De media, los usuarios de MyAllocator aumentan sus ingresos en un 20 % gracias a nuestro motor inteligente de precios dinámicos y a nuestro gestor de canales integrado.\n",
          "color": "#545454",
          "weight": "normal",
          "opacity": "100",
          "maxWidth": "md",
          "paddingY": "none",
          "alignment": "center",
          "animation": "none",
          "lineHeight": "normal",
          "animationDelay": "none",
          "animationDuration": "normal"
        }
      },
