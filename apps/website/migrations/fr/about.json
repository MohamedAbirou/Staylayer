        "props": {
          "id": "Heading-006398c5-93c0-42c9-8135-cd8dd6527295",
          "size": "xl",
          "text": "Notre parcours",
          "color": "",
          "level": "h2",
          "weight": "bold",
          "maxWidth": "none",
