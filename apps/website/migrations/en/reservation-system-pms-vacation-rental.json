      {
        "type": "FAQ",
        "props": {
          "id": "FAQ-899b68ea-103d-4c79-8d98-0ce5705a64cc",
          "items": [
            {
              "answer": "A PMS is software that helps vacation-rental owners and managers handle reservations, availability, payments, and guest communication online, replacing manual spreadsheets and double bookings.",
              "question": "What Is A Property Management System (PMS)?"
            },
            {
              "answer": "MyAllocator combines a full PMS with a two-way channel manager, giving you unified calendars, dynamic pricing, automated messaging, and financial reporting in one login.",
              "question": "How Is MyAllocator Different From A Standalone Channel Manager?"
